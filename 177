async function recoveryScan(env) {
  try {
    const tsNow = Date.now();
    const users = await getUsersIndex(env);
    if (!users.length) return;

    for (const psid of users) {
      const st = await loadState(psid, env);
      const lastAt = st.last_user_at || 0;
      if (!lastAt) continue;

      const hours = (Date.now() - lastAt) / 3600000;

      // Bridge FEET -> MAIN: dopo FEET2 pagato, proponi ingresso MAIN in finestra 3-12h (una sola volta)
      try {
        const bridgeMain = !!st.bridge_main;
        const mainLevel = Number(st.mainLevel || 0);
        const alreadySent = !!st.main_offer_sent;
        const hasQueued = Array.isArray(st.timed_queue) && st.timed_queue.some(it => it && it.action === "OFFER_MAIN_T1");
        if (bridgeMain && mainLevel < 1 && !alreadySent && !hasQueued) {
          const minMs = 3 * 3600000;
          const maxMs = 12 * 3600000;
          const at = Date.now() + minMs + Math.floor(Math.random() * (maxMs - minMs + 1));
          enqueueAction(st, "OFFER_MAIN_T1", at, {});
          await saveStateSafe(psid, st, env);
        }
      } catch (_) {}

      const waiting =
        st.awaiting_tier1_intro || st.awaiting_tier1_confirm ||
        st.awaiting_tier2_intro || st.awaiting_tier2_confirm ||
        st.awaiting_tier3_intro || st.awaiting_tier3_confirm ||
        st.awaiting_vip_intro  || st.awaiting_vip_confirm;

      if (!waiting) continue;
      if (hours < 24) continue;
      if (st.recovery_24h_sent) continue;

      const msg = applyUltraRealism(
        "Ehi... mi sei sparito 😏 Ti va di riprendere da dove ci siamo lasciati... o preferisci che resti un ricordo?",
        st
      );

      enqueueAction(st, "SEND_TEXT", Date.now() + 60000, { text: msg });

      st.recovery_24h_sent = true;
      st.recovery_24h_sent_at = new Date().toISOString();
      await saveStateSafe(psid, st, env);
    }
  } catch (e) {
    console.log("RECOVERY scan error", String(e));
  }
}

// V131: processa un singolo psid direttamente senza KV list (bypassa eventual consistency — per test)
async function processTimedQueueSingle(psid, env) {
  try {
    const stateKV = getStateKV(env);
    if (!stateKV) return;
    const nowTs = Date.now();
    const IDEM_WIN = 3 * 60 * 1000;
    const cronIdem = (st, key) => !!(st[key] && (Date.now() - st[key]) < IDEM_WIN);
    const fakeKey = { name: `state:${psid}` };
    await _processCronKeys([fakeKey], env, nowTs, cronIdem, stateKV);
  } catch(err) {
    console.error("CRON_SINGLE_ERROR", err?.message || err);
  }
}

async function processTimedQueue(env) {
  try {
    let cursor = undefined;
    const prefix = "state:";
    const nowTs = Date.now();
    // V117: finestra idempotenza per azioni critiche (3 minuti)
    // Se lo stesso SEND_TIER* è già stato processato meno di 3 min fa → skip
    const IDEM_WIN = 3 * 60 * 1000;
    const cronIdem = (st, key) => !!(st[key] && (Date.now() - st[key]) < IDEM_WIN);
    // V82 BUG #1 FIX: usa getStateKV() invece di env.CHAT_KV hardcoded
    // env.CHAT_KV potrebbe non esistere se il KV si chiama FUNNEL_STATE o LUNA_KV
    const stateKV = getStateKV(env);
    if (!stateKV) {
      console.error("❌ V82: processTimedQueue - nessun KV disponibile!");
      return;
    }

    while (true) {
      const listed = await stateKV.list({ prefix, cursor, limit: 1000 });
      const keys = listed.keys || [];
      cursor = listed.cursor;

      await _processCronKeys(keys, env, nowTs, cronIdem, stateKV);

      if (!cursor) break;
    }
  } catch (err) {
    console.error("CRON_PROCESS_ERROR", err?.message || err);
  }
}

// V131: corpo del loop CRON estratto per riuso in processTimedQueueSingle
async function _processCronKeys(keys, env, nowTs, cronIdem, stateKV) {
  for (const k of keys) {
        const keyName = k.name;
        const psid = keyName.slice("state:".length);
        const st = await loadState(psid, env);

        // V40 FIX: Sync paid flags from FUNNEL_STATE (source of truth)
        try {
          const payRaw = await env.FUNNEL_STATE?.get(`user:${psid}`)?.catch(() => null) ?? null;
          if (payRaw) {
            const funnelState = JSON.parse(payRaw);
            st.tier1_paid = !!funnelState.tier1_paid;
            st.tier2_paid = !!funnelState.tier2_paid;
            st.tier3_paid = !!funnelState.tier3_paid;
            st.vip_paid = !!funnelState.vip_paid;
            st.feet_tier1_paid = !!funnelState.feet_tier1_paid;
            st.feet_tier2_paid = !!funnelState.feet_tier2_paid;
            st.feet_tier3_paid = !!funnelState.feet_tier3_paid;
            st.feet_tier4_paid = !!funnelState.feet_tier4_paid;
          }
        } catch (e) {
          console.error(`CRON sync error for ${psid}:`, e.message);
        }

        // payState for CRON: derived from saved state (now synced with FUNNEL_STATE)
        const payState = {
          tier1_paid: !!st.tier1_paid,
          tier2_paid: !!st.tier2_paid,
          tier3_paid: !!st.tier3_paid,
          vip_paid: !!st.vip_paid,
          feet_tier1_paid: !!st.feet_tier1_paid,
          feet_tier2_paid: !!st.feet_tier2_paid,
          feet_tier3_paid: !!st.feet_tier3_paid,
          feet_tier4_paid: !!st.feet_tier4_paid,
        };
        // ── V128 FIX: OPT-OUT GATE spostato PRIMA del length check ──────────────
        // Così anche utenti con coda vuota (iniettata dopo opted_out) vengono coperti.
        if (st.opted_out) {
          if (Array.isArray(st.timed_queue) && st.timed_queue.length > 0) {
            console.log(`🚫 V128: CRON opted_out=true — coda svuotata psid=${psid}`);
            st.timed_queue = [];
            await saveStateSafe(psid, st, env);
          }
          continue;
        }
        // ── END OPT-OUT GATE ─────────────────────────────────────────────────────

        // ── V129: ACTIVE ESCALATION ──────────────────────────────────────────────
        // Push proattivo per utenti caldi che non triggerano keyword esplicite.
        // Posizione: dopo opt-out gate, PRIMA del length check → raggiunge anche
        // utenti con coda vuota. Il `continue` finale impedisce al V100 di
        // sovrascrivere la queue appena salvata con `remaining` vuoto.
        {
          const _AE_SILENCE_MIN =  20 * 60 * 1000;   // 20 min senza messaggi
          const _AE_SILENCE_MAX =  48 * 60 * 60 * 1000; // oltre 48h = dormiente
          const _AE_COOLDOWN    =   6 * 60 * 60 * 1000; // non ripetere per 6h

          const _aeSilence =
            !!st.last_user_msg_at &&
            (nowTs - st.last_user_msg_at) > _AE_SILENCE_MIN &&
            (nowTs - st.last_user_msg_at) < _AE_SILENCE_MAX;

          const _aeNoActiveFlow =
            !st.awaiting_payment_tier    &&
            !st.awaiting_offer           &&
            !st.awaiting_tier1_intro     && !st.awaiting_tier1_confirm &&
            !st.awaiting_feet_confirm;

          const _aeNoT1Queued = !(
            Array.isArray(st.timed_queue) &&
            st.timed_queue.some(q => q.action === "SEND_TIER1")
          );

          const _aeEligible =
            st.stage === "ACTIVE"              &&
            !!st.gift_sent                     &&
            st.tier1_sent === 0                &&
            !st.tier1_closed                   &&
            !st.tier1_paid  && !st.tier2_paid  &&
            !st.tier3_paid  && !st.vip_paid    &&
            _aeNoActiveFlow                    &&
            !st.regression_mode                &&
            st.user_type !== "DEAD"            &&
            !st.opted_out                      &&
            (st.desire    || 0) >= 2           &&  // V130: abbassato da 3 a 2 (gift_sent già segnale sufficiente)
            (st.msg_count || 0) >= 2           &&  // V130: abbassato da 4 a 2 (warmup standard)
            _aeSilence                         &&
            (!st._ae_at || (nowTs - st._ae_at) > _AE_COOLDOWN) &&
            !isQuietHours(nowTs)               &&
            _aeNoT1Queued;

          // V130: log diagnostico quando AE non scatta — utile per debug
          if (!_aeEligible && st.stage === "ACTIVE" && !!st.gift_sent && _aeSilence) {
            const _aeDiag = {
              stage: st.stage,
              gift_sent: !!st.gift_sent,
              tier1_sent: st.tier1_sent,
              tier1_paid: !!st.tier1_paid,
              aeNoActiveFlow: _aeNoActiveFlow,
              user_type: st.user_type,
              opted_out: !!st.opted_out,
              desire: st.desire || 0,
              msg_count: st.msg_count || 0,
              _aeSilence,
              _ae_cooldown_ok: !st._ae_at || (nowTs - st._ae_at) > _AE_COOLDOWN,
              quietHours: isQuietHours(nowTs),
              _aeNoT1Queued,
            };
            console.log(`⚠️ V130: AE skip psid=${psid} diag=${JSON.stringify(_aeDiag)}`);
          }

          if (_aeEligible) {
            st._live_mode = isLiveMode(env, st);
            st._ae_at     = nowTs;
            scheduleTwoStep(st, "SEND_TIER1");
            // NON setAwaitingOffer: lo farà SEND_TIER1 handler dopo fbSend
            await saveStateSafe(psid, st, env);
            console.log(`⚡ V130: AE psid=${psid} desire=${st.desire} msgs=${st.msg_count} silenzio=${Math.round((nowTs - st.last_user_msg_at) / 60000)}min`);
            continue; // salta V100 — preserva queue appena salvata
          }
        }
        // ── END V129 ─────────────────────────────────────────────────────────────

        if (!st || !Array.isArray(st.timed_queue) || st.timed_queue.length === 0) continue;


        console.log(`🔍 V83 CRON: psid=${psid} timed_queue=${JSON.stringify(st.timed_queue.map(x=>({a:x.action,at:x.at,delta:Math.round((x.at-Date.now())/1000)+'s'})))}`);

        // process in order
        st.timed_queue.sort((a, b) => (a.at || 0) - (b.at || 0));

        // V49/V67: Check T1 pressure window expiry (PRIMA del loop items)
        // V67 FIX: quando la finestra scade, NON resettare awaiting_payment_tier e NON mandare "Chiuso."
        // Il reentry viene gestito quando l'utente chiede di nuovo il link (handleAwaitPaymentT1LinkRequest CASE 2)
        // Se resettiamo awaiting_payment_tier=null, isAwaitingPayment diventa false e il reentry non parte mai
        if (st.t1_window_active && st.t1_window_expires_at && nowTs > st.t1_window_expires_at && !st.tier1_paid) {
          st.t1_window_active = false;
          // V172 FIX E: guardia zombie — se reset_epoch > t1_last_sent_at, la finestra è di un ciclo
          // precedente al reset → NON settare reentry_penalty_t1 (sarebbe un reentry fantasma)
          const _resetEpoch = Number(st.reset_epoch || 0);
          const _t1LastSent = Number(st.t1_last_sent_at || st.last_t1_link_sent_at || 0);
          const _isZombie = _resetEpoch > 0 && _t1LastSent > 0 && _resetEpoch > _t1LastSent;
          if (!st.reentry_used_t1 && !st.reentry_penalty_t1 && !_isZombie) {
            st.reentry_penalty_t1 = true;
            console.log(`⏱️ WINDOW T1 CHIUSA: scaduta ${new Date(st.t1_window_expires_at).toISOString()} → reentry_penalty_t1 attiva`);
          } else if (_isZombie) {
            console.log(`🚫 V172: T1 window zombie post-reset (reset_epoch=${_resetEpoch} > t1_last_sent=${_t1LastSent}) → skip reentry_penalty`);
          }
          st.timed_queue = st.timed_queue.filter(i => i.action !== "AWAIT_PAYMENT_FOLLOWUP");
        }
        // V67: log window chiusa per T2/T3/FEET1/FEET2 (il reentry è gestito dal gateway)
        if (st.t2_window_expires_at && nowTs > st.t2_window_expires_at && !st.tier2_paid && !st._t2_window_logged) {
          st._t2_window_logged = true;
          console.log(`⏱️ WINDOW T2 CHIUSA: scaduta ${new Date(st.t2_window_expires_at).toISOString()} → prossimo link sarà tier2_reentry`);
        }
        if (st.t3_window_expires_at && nowTs > st.t3_window_expires_at && !st.tier3_paid && !st._t3_window_logged) {
          st._t3_window_logged = true;
