// ============================================================================
// V87: _objectionFlow — modulato su user_type
// Modifiche rispetto a V86:
//   1. DEAD → non risponde (return null) — preserva engagement, non premia resistenza
//   2. COLD → cap a step 1. Step 2 non viene mai raggiunto: ritorna null
//      → il messaggio passa al flow normale (Groq o generic) invece di spingere
//   3. HOT + step 2 (price o delay) → override "hold" invece di chiudere la porta
//      → tiene aperta la conversazione su un utente ad alto desire
// Invariato: i testi OBJ_RESPONSES (già buoni, non riscriverli)
// ============================================================================
function _objectionFlow(st, type) {
  const key = `objection_stage_${type}`;
  const step = Math.min(st[key] || 0, 2);
  const userType = st.user_type || "COLD";

  // V87 FIX 1: DEAD → stop. Non premiare la resistenza.
  if (userType === "DEAD") {
    console.log(`🛑 V87: Obiezione ${type} ignorata — user_type=DEAD`);
    return null;
  }

  // V87 FIX 2: COLD → cap step 1.
  // Un utente freddo non è pronto per la pressione step 2.
  // Invece di spingere, lascia che il messaggio salga a Groq (più naturale).
  if (userType === "COLD" && step >= 2) {
    console.log(`🧊 V87: Obiezione ${type} step ${step} ignorata — user_type=COLD (cap step 1)`);
    // Non avanziamo lo step: lo teniamo a 2 così la prossima volta riprova
    return null;
  }

  // V87 FIX 3: HOT + step 2 su price o delay → non chiudere la porta.
  // "Capisco, non fa per te" su un HOT (desire>=7) è conversione persa.
  // Override: risposta di "hold" che tiene aperto + richiama il link.
  if ((userType === "HOT" || (st.desire || 0) >= 7) && step === 2 && (type === "price" || type === "delay")) {
    // Avanza lo step (si resetta a 0)
    st[key] = 0;
    const holdVariants = type === "price"
      ? [
          "Ok. Non ti premo. Ma il link è lì — se cambia qualcosa in 10 minuti, non ti aspetto.",
          "Capito. Non faccio pressione. Ma sai già dove sei.",
          "Va bene. Però il link non resta sempre aperto. Pensaci bene.",
        ]
      : [
          "Ok. Però 'dopo' sparisce in fretta. Sei ancora dentro, se vuoi.",
          "Capito. Il link è lì. Non chiudo subito.",
          "Ok. Ma tienilo in mente — non aspetto per sempre.",
        ];
    console.log(`🔥 V87: HOT step 2 ${type} → hold variant (non close)`);
    return holdVariants[Math.floor(Math.random() * holdVariants.length)];
  }

  // Flow standard: avanza step normalmente
  st[key] = (step >= 2) ? 0 : step + 1;

  // V104 FIX 3: mirror su campi unified objection_step + objection_type (compatibilità test)
  st.objection_type = type;
  st.objection_step = (st.objection_step || 0) + 1;

  const variants = OBJ_RESPONSES[type]?.[step];
  if (!variants || !variants.length) return null;
  return variants[Math.floor(Math.random() * variants.length)];
}

