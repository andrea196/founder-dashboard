      await fbSend(psid, chosen, env);
      console.log("✅ V60: Risposta deterministica in funnel (no/negativo)");
      await saveStateSafe(psid, st, env);
      return;
    }
    
    // Per altri messaggi generici in funnel
    // V77 FIX: NON intercettare keyword di obiezione — le obiezioni devono andare a Modulo 3
    const isObjectionKeyword = /(troppo|costa|caro|soldi|non so|sicura|funziona|dopo|ci penso|magari|non ora)/i.test(norm);
    if (norm.length < 20 && !/\?/.test(norm) && !isObjectionKeyword) {
