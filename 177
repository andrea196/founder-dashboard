        "reentry_link_sent_total","reentry_paid_total","reentry_revenue_total_cents",
        "reentry_link_sent_tier1_reentry","reentry_link_sent_tier2_reentry","reentry_link_sent_tier3_reentry",
        "reentry_link_sent_feet1_reentry","reentry_link_sent_feet2_reentry",
        "reentry_paid_tier1_reentry","reentry_paid_tier2_reentry","reentry_paid_tier3_reentry",
        "reentry_paid_feet1_reentry","reentry_paid_feet2_reentry",
        "reentry_revenue_tier1_reentry_cents","reentry_revenue_tier2_reentry_cents","reentry_revenue_tier3_reentry_cents",
        "reentry_revenue_feet1_reentry_cents","reentry_revenue_feet2_reentry_cents",
        "t1_reminder1_sent","t1_reminder2_sent",
        "t2_reminder1_sent","t2_reminder2_sent",
        "t3_reminder1_sent","t3_reminder2_sent",
        "feet1_reminder1_sent","feet1_reminder2_sent",
        "feet2_reminder1_sent","feet2_reminder2_sent",
        "t1_reentry_used","t2_reentry_used","t3_reentry_used",
        "feet1_reentry_used","feet2_reentry_used",
        "t1_lock_set","t2_lock_set","t3_lock_set","feet1_lock_set","feet2_lock_set",
      ];

      // Legge sia le bare keys (senza prefisso data) che le date-prefixed keys di oggi
      const bare = {};
      const dated = {};
      const pfx = `m:${today}:`;
      for (const k of allKeys) {
        const bv = await mkv.get(k).catch(() => null);
        const dv = await mkv.get(pfx + k).catch(() => null);
        if (bv !== null) bare[k] = bv;
        if (dv !== null) dated[pfx + k] = dv;
      }

      return corsResponse(JSON.stringify({
        metrics_kv_bound: true,
        today_rome: today,
        today_utc: new Date().toISOString().slice(0, 10),
        diagnosis: Object.keys(bare).length > 0 && Object.keys(dated).length === 0
          ? "⚠️ BARE KEYS TROVATE ma NESSUNA DATE-PREFIXED KEY — la dashboard mostra zero. Chiama POST /metrics/migrate per migrare."
          : Object.keys(dated).length > 0
          ? "✅ Date-prefixed keys presenti — la dashboard dovrebbe mostrare i dati."
          : "ℹ️ Nessun dato trovato per oggi.",
        bare_keys: bare,
        dated_keys_today: dated,
      }, null, 2), { status: 200, headers: { "Content-Type": "application/json" } });
    }

    // ============================================================================
    // V150: POST /metrics/migrate — migra bare keys → date-prefixed keys per una data specifica
    // Uso: POST /metrics/migrate?date=2026-02-23  (default: oggi Rome TZ)
    // SAFE: usa kvIncr (incrementa, non sovrascrive) — idempotente se già migrato.
    // Dopo la migrazione le bare keys vengono azzerate per evitare doppio conteggio.
    // ============================================================================
    if (req.method === "POST" && path === "/metrics/migrate") {
      const dashTokM = req.headers.get("X-DASH-TOKEN") || req.headers.get("X-API-Key") || "";
      const dashOkM = isAdmin || (dashTokM && env.DASH_TOKEN && dashTokM === env.DASH_TOKEN);
      if (!dashOkM) return corsResponse(JSON.stringify({ error: "Unauthorized" }), { status: 401, headers: { "Content-Type": "application/json" } });

      const mkv = env.METRICS_KV;
      if (!mkv) return corsResponse(JSON.stringify({ error: "METRICS_KV not configured" }), { status: 500, headers: { "Content-Type": "application/json" } });

      const targetDate = url.searchParams.get("date") || getRomeDayString();
      const migrateKeys = [
        "t1_link_sent","t2_link_sent","t3_link_sent","feet1_link_sent","feet2_link_sent",
        "t1_paid","t2_paid","t3_paid","feet1_paid","feet2_paid",
        "revenue_total_cents",
        "reentry_link_sent_total","reentry_paid_total","reentry_revenue_total_cents",
        "reentry_link_sent_tier1_reentry","reentry_link_sent_tier2_reentry","reentry_link_sent_tier3_reentry",
        "reentry_link_sent_feet1_reentry","reentry_link_sent_feet2_reentry",
        "reentry_paid_tier1_reentry","reentry_paid_tier2_reentry","reentry_paid_tier3_reentry",
        "reentry_paid_feet1_reentry","reentry_paid_feet2_reentry",
        "reentry_revenue_tier1_reentry_cents","reentry_revenue_tier2_reentry_cents","reentry_revenue_tier3_reentry_cents",
        "reentry_revenue_feet1_reentry_cents","reentry_revenue_feet2_reentry_cents",
        "t1_reminder1_sent","t1_reminder2_sent",
        "t2_reminder1_sent","t2_reminder2_sent",
        "t3_reminder1_sent","t3_reminder2_sent",
        "feet1_reminder1_sent","feet1_reminder2_sent",
        "feet2_reminder1_sent","feet2_reminder2_sent",
        "t1_reentry_used","t2_reentry_used","t3_reentry_used",
        "feet1_reentry_used","feet2_reentry_used",
        "t1_lock_set","t2_lock_set","t3_lock_set","feet1_lock_set","feet2_lock_set",
      ];

      const pfxMig = `m:${targetDate}:`;
      const migrated = {};
      const skipped = [];

      for (const k of migrateKeys) {
        try {
          const raw = await mkv.get(k).catch(() => null);
          if (raw === null || raw === "0" || raw === "") { skipped.push(k); continue; }
          const n = parseInt(raw, 10);
          if (!n || isNaN(n)) { skipped.push(k); continue; }
          // Incrementa la chiave date-prefixed del valore bare trovato
          await kvIncr(env, pfxMig + k, n);
          // Azzera la bare key per evitare doppio conteggio su future migrate
          await mkv.put(k, "0");
          migrated[k] = n;
        } catch(e) {
          console.warn(`migrate: errore su ${k}: ${e.message}`);
        }
      }

      console.log(`✅ V150: /metrics/migrate completato — ${Object.keys(migrated).length} chiavi migrate su ${targetDate}`);
      return corsResponse(JSON.stringify({
        ok: true,
        target_date: targetDate,
        migrated,
        migrated_count: Object.keys(migrated).length,
        skipped_count: skipped.length,
        message: `Chiavi migrate da bare → m:${targetDate}:*. Bare keys azzerate. Ricarica la dashboard.`,
      }, null, 2), { status: 200, headers: { "Content-Type": "application/json" } });
    }

    // POST /metrics/reset — azzera tutte le metriche degli ultimi 30 giorni (Rome TZ)
    // Chiamato direttamente dalla dashboard (no Messenger) — autentica con X-DASH-TOKEN
    // V148: questo endpoint risolve il problema "reset via Messenger non aggiorna la dash"
    if (req.method === "POST" && path === "/metrics/reset") {
      const dashTokR = req.headers.get("X-DASH-TOKEN") || req.headers.get("X-API-Key") || "";
      const dashOkR = isAdmin || (dashTokR && env.DASH_TOKEN && dashTokR === env.DASH_TOKEN);
      if (!dashOkR) return corsResponse(JSON.stringify({ error: "Unauthorized" }), { status: 401, headers: { "Content-Type": "application/json" } });

      const mkv = env.METRICS_KV;
      if (!mkv) return corsResponse(JSON.stringify({ error: "METRICS_KV not configured" }), { status: 500, headers: { "Content-Type": "application/json" } });

      const resetDays = [];
      for (let i = 0; i < 30; i++) {
        const d = new Date();
        d.setTime(d.getTime() - i * 86400000);
        resetDays.push(new Intl.DateTimeFormat("en-CA", {
          timeZone: "Europe/Rome", year: "numeric", month: "2-digit", day: "2-digit"
        }).format(d));
      }

      const resetKeys = [
        "t1_link_sent","t2_link_sent","t3_link_sent","feet1_link_sent","feet2_link_sent",
        "t1_paid","t2_paid","t3_paid","feet1_paid","feet2_paid",
        "revenue_total_cents",
        "reentry_link_sent_total","reentry_paid_total","reentry_revenue_total_cents",
        "reentry_link_sent_tier1_reentry","reentry_link_sent_tier2_reentry","reentry_link_sent_tier3_reentry",
        "reentry_link_sent_feet1_reentry","reentry_link_sent_feet2_reentry",
        "reentry_paid_tier1_reentry","reentry_paid_tier2_reentry","reentry_paid_tier3_reentry",
        "reentry_paid_feet1_reentry","reentry_paid_feet2_reentry",
        "reentry_revenue_tier1_reentry_cents","reentry_revenue_tier2_reentry_cents","reentry_revenue_tier3_reentry_cents",
        "reentry_revenue_feet1_reentry_cents","reentry_revenue_feet2_reentry_cents",
        "t1_reminder1_sent","t1_reminder2_sent",
        "t2_reminder1_sent","t2_reminder2_sent",
        "t3_reminder1_sent","t3_reminder2_sent",
        "feet1_reminder1_sent","feet1_reminder2_sent",
        "feet2_reminder1_sent","feet2_reminder2_sent",
        "t1_reentry_used","t2_reentry_used","t3_reentry_used",
        "feet1_reentry_used","feet2_reentry_used",
        "t1_lock_set","t2_lock_set","t3_lock_set","feet1_lock_set","feet2_lock_set",
      ];

      let done = 0;
      for (const day of resetDays) {
        for (const k of resetKeys) {
          try { await mkv.put(`m:${day}:${k}`, "0"); done++; } catch(_e) {}
        }
      }

      console.log(`✅ V148: /metrics/reset completato — ${done} chiavi azzerate`);
      return corsResponse(JSON.stringify({ ok: true, cleared: done, days: resetDays.length }), { status: 200, headers: { "Content-Type": "application/json" } });
    }

    // GET /metrics?range=1d|7d|30d — legge METRICS_KV e restituisce JSON strutturato
    if (req.method === "GET" && path === "/metrics") {
      const dashTok = req.headers.get("X-DASH-TOKEN") || url.searchParams.get("tok") || "";
      // V128 FIX: accetta X-API-Key (isAdmin) anche senza X-DASH-TOKEN
      const dashOk = isAdmin || (dashTok && (
        (env.DASH_TOKEN && dashTok === env.DASH_TOKEN)
      ));
      if (!dashOk) return corsResponse(JSON.stringify({ error: "Unauthorized" }), { status: 401, headers: { "Content-Type": "application/json" } });

      const rangeStr = url.searchParams.get("range") || "7d";
      // V147 FIX: 14d non era gestito → cadeva nel default 7 (mostrava 7D invece di 14D)
      const days = rangeStr === "1d" ? 1 : rangeStr === "7d" ? 7 : rangeStr === "14d" ? 14 : rangeStr === "30d" ? 30 : 7;

      // Raccoglie date nel range — usa Rome TZ (stesso di getRomeDayString usato dai writer)
      const dateKeys = [];
      for (let i = days - 1; i >= 0; i--) {
        const d = new Date();
        d.setTime(d.getTime() - i * 86400000);
        const dayStr = new Intl.DateTimeFormat("en-CA", {
          timeZone: "Europe/Rome",
          year: "numeric", month: "2-digit", day: "2-digit"
        }).format(d);
        dateKeys.push(dayStr);
      }

      const mkv = env.METRICS_KV;
      async function mget(key) {
        if (!mkv) return 0;
        const v = await mkv.get(key).catch(() => null);
        return v ? parseInt(v, 10) || 0 : 0;
      }

      // Aggregazione per range
      const tiers = ["t1", "t2", "t3", "feet1", "feet2"];
      const metrics = ["paid", "link_sent", "reminder1_sent", "reminder2_sent", "reentry_used", "lock_set"];
      const agg = {};
      for (const t of tiers) {
        agg[t] = {};
        for (const m of metrics) agg[t][m] = 0;
      }
      let revenueTotal = 0;
      let activeUsers = new Set();

      // V141: aggregatori reentry
      const reentryKinds = ["tier1_reentry","tier2_reentry","tier3_reentry","feet1_reentry","feet2_reentry"];
      const reAgg = {
        link_sent: { total: 0 },
        paid:      { total: 0 },
        revenue_cents: { total: 0 },
      };
      for (const k of reentryKinds) {
        reAgg.link_sent[k] = 0;
        reAgg.paid[k]      = 0;
        reAgg.revenue_cents[k] = 0;
      }

      // V157: nuovi aggregatori ops
      const opsAgg = { messages: 0, new_users: 0, objections: 0, regression: 0, groq_calls: 0 };
      const tipAgg = { count: 0, revenue_cents: 0 };
      const objByType = { MONEY:0, TRUST:0, TIME:0, FREE:0, CONTENT:0, VALUE:0, BOT:0, NO:0 };

      await Promise.all(dateKeys.map(async (day) => {
        const prefix = `m:${day}:`;
        for (const t of tiers) {
          for (const m of metrics) {
            const v = await mget(prefix + `${t}_${m}`);
            agg[t][m] += v;
          }
        }
        const rev = await mget(prefix + "revenue_total_cents");
        revenueTotal += rev;
        // V157: aggrega ops
        opsAgg.messages   += await mget(prefix + "messages_total");
        opsAgg.new_users  += await mget(prefix + "new_users");
        opsAgg.objections += await mget(prefix + "objections_total");
        opsAgg.regression += await mget(prefix + "regression_count");
        opsAgg.groq_calls += await mget(prefix + "groq_calls");
        tipAgg.count         += await mget(prefix + "tip_count");
        tipAgg.revenue_cents += await mget(prefix + "tip_revenue_cents");
        for (const ot of ["MONEY","TRUST","TIME","FREE","CONTENT","VALUE","BOT","NO"]) {
          objByType[ot] += await mget(prefix + `objection_${ot}`);
        }

        // V141: aggrega reentry
        reAgg.link_sent.total  += await mget(prefix + "reentry_link_sent_total");
        reAgg.paid.total       += await mget(prefix + "reentry_paid_total");
        reAgg.revenue_cents.total += await mget(prefix + "reentry_revenue_total_cents");
        for (const k of reentryKinds) {
          reAgg.link_sent[k]     += await mget(prefix + `reentry_link_sent_${k}`);
          reAgg.paid[k]          += await mget(prefix + `reentry_paid_${k}`);
          reAgg.revenue_cents[k] += await mget(prefix + `reentry_revenue_${k}_cents`);
        }
      }));

      // Calcola KPI
      const totalPaid = tiers.reduce((s, t) => s + agg[t].paid, 0);
      const totalLinks = tiers.reduce((s, t) => s + agg[t].link_sent, 0);
      const t1Conv = totalLinks > 0 ? agg.t1.paid / Math.max(agg.t1.link_sent, 1) : 0;
      const t2t3Upgrade = agg.t2.paid > 0 ? agg.t3.paid / agg.t2.paid : 0;
      const arppu = totalPaid > 0 ? Math.round(revenueTotal / totalPaid) : 0;

      // Costruisci risposta strutturata
      const result = {
        range: rangeStr,
        period: { days, from: dateKeys[0], to: dateKeys[dateKeys.length - 1] },
        generated_at: new Date().toISOString(),
        kpi: {
          revenue_range_cents: revenueTotal,
          total_paid_range: totalPaid,
          t1_conversion_range: Math.min(1, t1Conv),
          t2_to_t3_upgrade_range: Math.min(1, t2t3Upgrade),
          arppu_range_cents: arppu,
        },
        tiers: {},
        upgrades: {
          t1_to_t2: agg.t2.paid,
          t2_to_t3: agg.t3.paid,
          to_feet1: agg.feet1.paid,
          to_feet2: agg.feet2.paid,
        },
        levers: {
          reminder_sent_total: tiers.reduce((s, t) => s + agg[t].reminder1_sent + agg[t].reminder2_sent, 0),
          reentry_used_total: tiers.reduce((s, t) => s + agg[t].reentry_used, 0),
          locks_set_total: tiers.reduce((s, t) => s + agg[t].lock_set, 0),
        },
        ops: {
          active_users_24h: await mget(`m:${dateKeys[dateKeys.length - 1]}:active_count`),
          new_users_range: opsAgg.new_users,
          messages_total_range: opsAgg.messages,
          groq_calls_range: opsAgg.groq_calls,
        },
        objections: {
          total_range: opsAgg.objections,
          by_type: objByType,
          regression_count_range: opsAgg.regression,
        },
        tip: {
          count_range: tipAgg.count,
          revenue_cents_range: tipAgg.revenue_cents,
          avg_tip_cents: tipAgg.count > 0 ? Math.round(tipAgg.revenue_cents / tipAgg.count) : 0,
          // V175: Percentuale tip su revenue totale per dashboard
          revenue_pct: revenueTotal > 0 ? Math.round((tipAgg.revenue_cents / revenueTotal) * 10000) / 100 : 0,
        },
        // V141: blocco reentry analytics
        reentry: {
          link_sent: reAgg.link_sent,
          paid:      reAgg.paid,
          revenue_cents: reAgg.revenue_cents,
          cvr: {
            total: reAgg.link_sent.total > 0
              ? Math.round((reAgg.paid.total / reAgg.link_sent.total) * 10000) / 10000
              : null,
            ...Object.fromEntries(reentryKinds.map(k => [
              k,
              reAgg.link_sent[k] > 0
                ? Math.round((reAgg.paid[k] / reAgg.link_sent[k]) * 10000) / 10000
                : null
            ])),
          },
        },
      };
      for (const t of tiers) {
        result.tiers[t] = {
          paid_range: agg[t].paid,
          link_sent_range: agg[t].link_sent,
          conversion_range: agg[t].link_sent > 0 ? Math.min(1, agg[t].paid / agg[t].link_sent) : 0,
          reminder1_sent_range: agg[t].reminder1_sent,
          reminder2_sent_range: agg[t].reminder2_sent,
          reentry_used_range: agg[t].reentry_used,
          lock_set_range: agg[t].lock_set,
        };
      }

      return corsResponse(JSON.stringify(result), { status: 200, headers: { "Content-Type": "application/json" } });
    }

    // V151 FIX T1.5: catch-all GET con try/catch — garantisce sempre 200 "OK" anche su errori inattesi
    if (req.method === "GET") {
      try { return verifyGET(url, env); }
      catch (e) { console.error("[catch-all GET] errore:", e); return corsResponse("OK", { status: 200 }); }
    }
    if (req.method !== "POST") return corsResponse("OK", { status: 200 });

    // =====================================================================
    // V68: /api/gateway-abandoned
    // Beacon inviato dal gateway quando l'utente chiude la tab senza pagare.
    // Schedula GATEWAY_ABANDON_RETRY (messaggio 1) con delay 2-4 min.
    // =====================================================================
    if (path === "/api/gateway-abandoned") {
      try {
        const body = await req.json().catch(() => null);
        const psid = body?.psid;
        const tier = body?.tier || "tier1";
        if (!psid) {
          console.log("⚠️ V68: gateway-abandoned: PSID mancante, skip");
          return corsResponse(JSON.stringify({ ok: true }), { status: 200, headers: { "Content-Type": "application/json" } });
        }

        console.log(`🚪 V68: GATEWAY ABANDONED - PSID: ${psid}, tier: ${tier}`);

        const st = await loadState(psid, env);

        // Non inviare se l'utente ha già pagato quel tier
        const alreadyPaid = {
          tier1: st.tier1_paid,
          tier1_reentry: st.tier1_paid,
          tier2: st.tier2_paid,
          tier2_reentry: st.tier2_paid,
          tier3: st.tier3_paid,
          tier3_reentry: st.tier3_paid,
          feet1: st.feet_tier1_paid,
          feet1_reentry: st.feet_tier1_paid,
          feet2: st.feet_tier2_paid,
          feet2_reentry: st.feet_tier2_paid,
        };
        if (alreadyPaid[tier]) {
          console.log(`✅ V68: ${psid} ha già pagato ${tier}, skip abbandono`);
          return corsResponse(JSON.stringify({ ok: true, skipped: "already_paid" }), { status: 200, headers: { "Content-Type": "application/json" } });
        }

        // Evita scheduling duplicato: non schedulare se c'è già un GATEWAY_ABANDON_RETRY in coda
        const alreadyQueued = (st.timed_queue || []).some(i => 
          i.action === "GATEWAY_ABANDON_RETRY" && i.payload?.tier === tier
        );
        if (alreadyQueued) {
          console.log(`ℹ️ V68: GATEWAY_ABANDON_RETRY già in coda per ${psid}/${tier}, skip`);
          return corsResponse(JSON.stringify({ ok: true, skipped: "already_queued" }), { status: 200, headers: { "Content-Type": "application/json" } });
        }

        // Delay 2-4 minuti (abbastanza da non sembrare spam, abbastanza corto da essere caldo)
        const delayMs = (2 * 60 * 1000) + Math.floor(Math.random() * (2 * 60 * 1000));
        const retryAt = Date.now() + delayMs;

        const retryMessages = [
          "Hai visto il link ma sei uscita.\n\nNon mi offendo.\nMa il prezzo cambia se aspetti.",
          "Eri lì.\n\nHai guardato il prezzo e sei uscita.\n\nHo ancora il link aperto per te. Per ora.",
          "Il link era lì.\n\nSe vuoi ancora entrare, dimmelo adesso.\nFra poco lo chiudo.",
        ];
        const msg = retryMessages[Math.floor(Math.random() * retryMessages.length)];

        if (!Array.isArray(st.timed_queue)) st.timed_queue = [];
        st.timed_queue.push({
          action: "GATEWAY_ABANDON_RETRY",
          at: retryAt,
          reason: `gateway_abandon_${tier}_v68`,
          payload: { message: msg, tier }
        });
        // V124 FIX: rimosso il double-push _ps_compat — causava invio doppio del messaggio.
        // Il _ps_compat era stato aggiunto per PS 5.1 .Count compat ma non serve qui:
        // GATEWAY_ABANDON_RETRY non usa scheduleTwoStep e il cap V124 copre eventuali duplicati.

        await saveStateSafe(psid, st, env);
        console.log(`⏰ V68: GATEWAY_ABANDON_RETRY schedulato per ${psid} in ${Math.round(delayMs/1000)}s (tier: ${tier})`);

      } catch (e) {
        console.error("❌ V68: Errore gateway-abandoned:", e.message);
      }
      return corsResponse(JSON.stringify({ ok: true }), { status: 200, headers: { "Content-Type": "application/json" } });
    }

    // V101 FIX CRITICO: /webhook è alias di /fb (path già normalizzato sopra)
    if (path !== "/fb" && path !== "/webhook") return corsResponse("OK", { status: 200 });

    const body = await req.json().catch(() => null);
    if (!body) return corsResponse("OK", { status: 200 });

    // V138 FIX: Supporto formato diretto {psid, text} usato dal test suite.
    // Il formato Facebook Messenger usa body.entry[].messaging[].
    // Il test suite (PowerShell) invia direttamente { psid: "...", text: "..." }.
    // Se body.psid e body.text sono presenti, processiamo direttamente.
    if (body.psid && body.text) {
      console.log(`🔵 V138: /webhook formato diretto psid=${body.psid} text="${String(body.text).substring(0, 30)}"`);
      try {
        await handleText(body.psid, body.text, env);
      } catch (e) {
        console.error("HANDLE_TEXT_CRASH (direct)", body.psid, e?.message || String(e), e?.stack?.split("\n")[1] || "");
        await testLog(body.psid, "HANDLE_TEXT_CRASH", { error: e?.message || String(e), stack: e?.stack?.split("\n").slice(0,3).join(" | ") }, env).catch(() => {});
      }
      return corsResponse("OK", { status: 200 });
    }

    for (const e of (body?.entry || [])) {
      for (const m of (e.messaging || [])) {
        if (m.message && !m.message.is_echo) {
          const psid = m.sender?.id;
          const text = m.message?.text;
          const msgId = m.message?.mid;
          
          if (psid && text) {
            // V95 FIX: isDuplicate wrapped in try/catch — se crasha non blocca handleText
            let _dup = false;
            try { _dup = msgId ? await isDuplicate(msgId, env) : false; } catch (_de) {
              console.warn("isDuplicate_crash (non-fatal):", String(_de));
            }
