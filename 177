.page{max-width:640px;margin:0 auto;padding:0 18px 64px;}

/* HEADER */
.hdr{padding:40px 0 28px;text-align:center;border-bottom:1px solid var(--bd);margin-bottom:32px;animation:fD .55s ease both;}
.hdr-logo{font-size:10px;letter-spacing:.38em;color:var(--gold);text-transform:uppercase;opacity:.6;margin-bottom:10px;}
.hdr-title{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:clamp(26px,5.5vw,38px);font-weight:300;line-height:1.1;margin-bottom:6px;}
.hdr-tier{font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--gr);}

/* WELCOME BANNER */
.banner{background:linear-gradient(135deg,#111,#0d0d0d);border:1px solid var(--bd2);border-left:2px solid var(--gold);padding:16px 20px;border-radius:2px;margin-bottom:32px;animation:fU .45s .12s ease both;}
.banner-txt{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:15px;color:var(--wh);opacity:.82;line-height:1.55;}
.banner-tier{margin-top:6px;font-size:9px;letter-spacing:.22em;color:var(--gold);text-transform:uppercase;opacity:.55;}

/* SECTION HEADER */
.section-head{display:flex;align-items:center;gap:10px;margin-bottom:14px;animation:fD .4s ease both;}
.sec-icon{font-size:13px;}
.sec-label{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);opacity:.75;}
.sec-count{margin-left:auto;font-size:10px;color:var(--gr2);letter-spacing:.08em;}

/* GRID */
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:7px;margin-bottom:32px;}

/* CARD */
.card{background:var(--bg2);border:1px solid var(--bd);border-radius:3px;overflow:hidden;animation:fU .4s ease both;opacity:0;animation-fill-mode:both;transition:border-color .2s,transform .2s,box-shadow .2s;}
.card:hover{border-color:var(--gold);transform:translateY(-2px);box-shadow:0 8px 20px rgba(184,147,90,.1);}
.card a{display:flex;flex-direction:column;text-decoration:none;color:inherit;}

/* THUMB */
.thumb{width:100%;aspect-ratio:3/2;position:relative;overflow:hidden;background:var(--bg3);}
.thumb-bg{position:absolute;inset:0;background:linear-gradient(135deg,#131313,#090909);transition:opacity .2s;}
.card:hover .thumb-bg{opacity:.6;}
.photo-bg{background:linear-gradient(135deg,#12100d,#0a0806);}
/* Play button */
.play-ring{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:16px;color:rgba(255,255,255,.35);}
.card:hover .play-ring{color:rgba(184,147,90,.7);}
/* Badges */
.badge{position:absolute;top:5px;right:5px;font-size:8px;letter-spacing:.07em;text-transform:uppercase;background:rgba(0,0,0,.65);color:var(--gold);padding:2px 5px;border-radius:1px;border:1px solid rgba(184,147,90,.25);}
.dur,.sz{position:absolute;bottom:5px;right:5px;font-size:8px;background:rgba(0,0,0,.6);color:rgba(240,236,230,.6);padding:1px 4px;border-radius:1px;}

/* FILE NAME + DL */
.fname{font-size:10px;color:var(--wh);opacity:.6;padding:8px 10px 2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;letter-spacing:.01em;}
.dl{font-size:11px;color:var(--gr2);padding:0 10px 8px;transition:color .15s;}
.card:hover .dl{color:var(--gold);}

/* DOWNLOAD OVERLAY */
.card:hover::after{content:'↓';position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(184,147,90,.05);font-size:20px;color:rgba(184,147,90,.4);pointer-events:none;}

/* DIVIDER */
.div{border:none;border-top:1px solid var(--bd);margin:0 0 28px;}

/* EMPTY */
.empty{text-align:center;padding:36px 20px;color:var(--gr2);}
.empty-icon{font-size:30px;margin-bottom:10px;opacity:.25;}
.empty-label{font-size:11px;letter-spacing:.14em;text-transform:uppercase;margin-bottom:6px;}
.empty-sub{font-size:11px;color:var(--gr2);opacity:.6;}

/* FOOTER */
.ftr{text-align:center;padding-top:28px;border-top:1px solid var(--bd);}
.ftr-txt{font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:var(--gr2);line-height:2;}
.ftr-exp{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:13px;color:var(--gr);margin-top:4px;}

/* ANIMS */
@keyframes fD{from{opacity:0;transform:translateY(-10px)}to{opacity:1;transform:none}}
@keyframes fU{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
</style>
</head>
<body>
<div class="page">

  <div class="hdr">
    <div class="hdr-logo">Accesso Privato</div>
    <div class="hdr-title">${welcomeMsg}</div>
    <div class="hdr-tier">${tierLabel}</div>
  </div>

  <div class="banner">
    <div class="banner-txt">Grazie per esserci. Questo è solo per te. 🖤</div>
    <div class="banner-tier">${tierLabel} · Accesso confermato</div>
  </div>

  ${emptyMsg}
  ${fotoSection}
  ${videoSection}

  <div class="ftr">
    <div class="ftr-txt">Link personale · non condividere</div>
    <div class="ftr-exp">Accesso attivo 48 ore dall'acquisto</div>
  </div>

</div>
</body>
</html>`;
}
