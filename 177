export default {
  async fetch(req, env, ctx) {
    // V74: OPTIONS handler
    if (req.method === "OPTIONS") {
      return new Response(null, { status: 204, headers: CORS_HEADERS });
    }
    // V74: Call handleRequest directly - no wrapper overhead
    return await handleRequest(req, env, ctx);
  },
  async scheduled(event, env, ctx) {
    console.log("CRON_TICK", new Date().toISOString());
    ctx.waitUntil(Promise.all([processTimedQueue(env), recoveryScan(env)]));
