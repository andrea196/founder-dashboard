// ----------  V12.1: HARD SENTENCE LIMITER ----------
function limitSentences(text, max = 3) {
  // Split su punteggiatura forte
  const parts = text.split(/(?<=[.!?])\s+/);
  
  // Prendi max N frasi
  const limited = parts.slice(0, max).join(" ");
  
  // Se è ancora troppo lungo (>150 char), taglia
  if (limited.length > 150) {
    return limited.substring(0, 147) + "...";
  }
  
  return limited;
}

