/**
 * Scrive un log strutturato su KV (testlog:${psid}).
 * TTL 2 ore — si autoelimina. Max 100 entry per psid.
 */
async function testLog(psid, event, data, env) {
  if (!env.WHOP_TEST_SECRET) return; // solo in test mode
  try {
    const kv = getStateKV(env);
    const key = `testlog:${psid}`;
    const existing = await kv.get(key).catch(() => null);
    const logs = existing ? JSON.parse(existing) : [];
    logs.push({ ts: Date.now(), event, data });
    if (logs.length > 100) logs.splice(0, logs.length - 100);
    await kv.put(key, JSON.stringify(logs), { expirationTtl: 7200 });
  } catch (e) { /* silent */ }
}

