        if (navigator.sendBeacon) {
          navigator.sendBeacon("/api/gateway-abandoned", new Blob([payload], { type: "application/json" }));
        } else {
          // Fallback sincrono per browser vecchi
          try {
            const xhr = new XMLHttpRequest();
            xhr.open("POST", "/api/gateway-abandoned", false); // sync
            xhr.setRequestHeader("Content-Type", "application/json");
            xhr.send(payload);
          } catch(e) {}
        }
      }

      // V68: pagehide è più affidabile di beforeunload su mobile/Safari
      window.addEventListener("pagehide", sendAbandonBeacon);
      // Fallback per desktop
      window.addEventListener("beforeunload", sendAbandonBeacon);
      // visibilitychange: cattura anche quando l'utente switcha tab e non torna
      document.addEventListener("visibilitychange", () => {
        if (document.visibilityState === "hidden") sendAbandonBeacon();
      });

