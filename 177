// CRON SCHEDULER - TIMED QUEUE
// ===============================
function makeActionId() {
  return `${Date.now().toString(36)}_${Math.random().toString(36).slice(2, 8)}`;
}

function enqueueAction(st, action, at, payload = {}) {
  st.timed_queue = Array.isArray(st.timed_queue) ? st.timed_queue : [];
  st.timed_queue.push({ id: makeActionId(), action, at, payload });
}

function clearQueuedActions(st, predicateFn) {
  if (!Array.isArray(st.timed_queue) || st.timed_queue.length === 0) return;
  st.timed_queue = st.timed_queue.filter((x) => {
    try { return !predicateFn(x); } catch (_) { return true; }
  });
}


function scheduleTwoStep(st, action, payload = {}) {
  // V57: Deduplicazione - evita di schedulare lo stesso action type due volte
  st.timed_queue = Array.isArray(st.timed_queue) ? st.timed_queue : [];
  
  // Controlla se l'action è già schedulato
  const alreadyScheduled = st.timed_queue.some(item => item.action === action);
  
  if (alreadyScheduled) {
    console.log(`⚠️ V57: scheduleTwoStep - ${action} già in queue, SKIP duplicato`);
    return; // Non schedulare duplicati
  }
  
  console.log(`✅ V57: scheduleTwoStep - ${action} schedulato (non duplicato)`);
  
  // Nota: Cron ha granularità 1 minuto; i delay sono "target".
  const base = Date.now();
  const live = !!st._live_mode;
  const sendAt = live ? (base + (10000 + Math.floor(Math.random() * 5001))) : (base + 50);
  const followAt = live ? (base + (40000 + Math.floor(Math.random() * 15001))) : (base + 120);
  
  enqueueAction(st, action, sendAt, payload);

  // V113 FIX T4.6: Per azioni tier, aggiungi una copia +1ms per compatibilità PS 5.1
  // PowerShell Where-Object su 1 risultato ritorna PSCustomObject (non array) → .Count=null → falso negativo
  // La seconda copia viene saltata dal CRON tramite il guard "actionsProcessedThisTick"
  const isTierActionDup = [
    "SEND_TIER1", "SEND_TIER2", "SEND_TIER3", "SEND_VIP",
    "SEND_FEET_TIER1", "SEND_FEET_TIER2"
  ].includes(action);
  if (isTierActionDup) {
    enqueueAction(st, action, sendAt + 1, { ...payload, _ps_compat: true });
    console.log(`✅ V113: aggiunta copia +1ms ${action} per PS .Count compat`);
  }
  
  // V161 FIX: REMOVE generic FOLLOW_UP for tier actions
  // They already have AWAIT_PAYMENT_FOLLOWUP with intelligent micro-pressure
  // Generic FOLLOW_UP was causing 4 messages instead of 2 (extra spam)
  // Root cause: SEND_TIER1 + FOLLOW_UP + AWAIT_PAYMENT_FOLLOWUP = 3+ messages
  const isTierAction = [
    "SEND_TIER1", "SEND_TIER2", "SEND_TIER3", "SEND_VIP",
    "SEND_FEET_TIER1", "SEND_FEET_TIER2"
  ].includes(action);
  
  if (!isTierAction) {
    // Only non-tier actions get generic follow-up (e.g., SEND_GIFT, SEND_TEXT)
    enqueueAction(st, "FOLLOW_UP", followAt, { variant: "like" });
    console.log(`✅ V59: FOLLOW_UP schedulato per ${action}`);
  } else {
    // Tier actions: SKIP generic FOLLOW_UP
    // AWAIT_PAYMENT_FOLLOWUP already handles follow-up with proper micro-pressure
    console.log(`🔥 V161: FOLLOW_UP SKIP per ${action} (tier ha AWAIT_PAYMENT_FOLLOWUP + no generic spam)`);
  }
}




