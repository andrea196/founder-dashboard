// V137: estrae il nome dell'utente da pattern espliciti di auto-presentazione.
// Usa solo pattern sicuri — esclude "sono X" (troppo ambiguo in italiano).
// Blacklist di parole comuni non-nome per evitare falsi positivi.
// Ritorna il nome capitalizzato (es. "marco" → "Marco") o null se non trovato.
function extractUserName(text) {
  const t = String(text || "").trim();
  // Pattern sicuri: "mi chiamo X", "chiamami X", "mi puoi chiamare X", "mi chiaman X"
  const m = t.match(/\b(?:mi chiamo|chiamami|mi puoi chiamare|mi chiamano|il mio nome [eè]|mi chiaman[o]?)\s+([A-Za-zÀ-ÖØ-öø-ÿ]{2,15})\b/i); // V138 FIX: aggiunto "il mio nome è"
  if (!m) return null;
  const raw = m[1];
  // Blacklist: parole italiane comuni che non sono nomi propri
  const blacklist = /^(bene|male|cosi|così|niente|nulla|tutto|solo|anche|già|gia|ancora|sempre|spesso|poco|molto|tanto|forse|okay|certo|vero|falso|no|si|sì|ok|dai|hey|ciao|grazie|prego|scusa|perfetto|bellissima|bellissimo|stanco|stanca|pronto|pronta|qui|qua|li|là|la|bella|bello|bravo|brava|gentile|simpatico|simpatica|carino|carina|ragazza|ragazzo|amore|tesoro|cara|caro|quello|quella|questo|questa|tale|nessuno|nessuna|tutti|tutte)$/i;
  if (blacklist.test(raw)) return null;
  // Capitalizza prima lettera, resto minuscolo
  return raw.charAt(0).toUpperCase() + raw.slice(1).toLowerCase();
}

