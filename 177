function getRomeDayString() {
  try {
    const now = new Date();
    const fmt = new Intl.DateTimeFormat('en-CA', {
      timeZone: 'Europe/Rome',
      year: 'numeric',
      month: '2-digit',
      day: '2-digit'
    });
    // en-CA => YYYY-MM-DD
    return fmt.format(now);
  } catch (e) {
    // fallback safe (UTC day)
    const d = new Date();
    const yyyy = d.getUTCFullYear();
    const mm = String(d.getUTCMonth() + 1).padStart(2, '0');
    const dd = String(d.getUTCDate()).padStart(2, '0');
    return `${yyyy}-${mm}-${dd}`;
  }
}

async function kvIncr(env, key, delta) {
  if (!env || !env.METRICS_KV) return null;
  const curRaw = await env.METRICS_KV.get(key);
  const cur = curRaw ? parseInt(curRaw, 10) : 0;
  const safeCur = Number.isFinite(cur) ? cur : 0;
  const next = safeCur + delta;
  await env.METRICS_KV.put(key, String(next));
  return next;
}

