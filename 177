function stripUrls(s) {
  return String(s || "").replace(/https?:\/\/\S+/gi, "").trim();
}

function rememberRecent(arr, item, max = 5) {
  const out = Array.isArray(arr) ? arr.slice(0) : [];
  const v = typeof item === "string" ? item.trim() : "";
  if (v) out.unshift(v);
  const seen = new Set();
  const deduped = [];
  for (const x of out) {
    if (!x) continue;
    if (seen.has(x)) continue;
    seen.add(x);
    deduped.push(x);
    if (deduped.length >= max) break;
  }
  return deduped;
}

