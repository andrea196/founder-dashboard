// V86 FIX: normalizza accenti italiani (e internazionali) → ASCII
// Necessario perché client (es. PowerShell, Facebook) possono inviare
// varianti Unicode diverse: "più" U+00F9 vs "piu" U+0075 non si sovrappongono
// con String.includes(). Deaccent le rende equivalenti.
function deaccentText(s) {
  return String(s || "")
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, ""); // rimuove diacritici (accenti, cedille, ecc.)
}

function v18ContainsTrigger(text, list) {
  const t = deaccentText(String(text || "").toLowerCase());
  return list.some(w => t.includes(deaccentText(w)));
}

