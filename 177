// MODULO 1: Classificazione utente (soglie deterministiche, zero AI)
function updateUserClassification(st) {
  if (st.tier1_paid || st.tier2_paid || st.tier3_paid || st.vip_paid) {
    st.user_type = "PURCHASED";
    return;
  }
  if ((st.strong_refusals || 0) >= 3) {
    st.user_type = "DEAD";
    return;
  }
  const d = st.desire || 0;
  if (d >= 7)      st.user_type = "HOT";
  else if (d >= 4) st.user_type = "WARM";
  else             st.user_type = "COLD";
}

// MODULO 2: Decide se fare auto-push T1 (SOLO T1 — opzione A)
function shouldAutoPush(st) {
  // Blocca se c'è già un pagamento in attesa
  if (st.awaiting_payment_tier) return false;
  // Blocca se ha già comprato
  if (st.tier1_paid || st.tier2_paid || st.tier3_paid || st.vip_paid) return false;
  // Blocca se è DEAD
  if (st.user_type === "DEAD") return false;
  // Auto-push SOLO T1 (opzione A)
  if (st.user_type === "HOT"  && (st.msg_count || 0) >= 6)  return true;
  if (st.user_type === "WARM" && (st.msg_count || 0) >= 10) return true;
  // V105b FIX: desire-based fallback — updateUserClassification classifica desire=6 come WARM,
  // ma il test 2.1 (e produzione reale) richede push con desire>=5 e msg>=6.
  // user_type è sovrascritta dal worker PRIMA del shouldAutoPush, quindi non possiamo
  // fidarcene per utenti con desire 5-6 (WARM, non HOT). Aggiunta condizione esplicita.
  if ((st.desire || 0) >= 5 && !st.tier1_paid && (st.msg_count || 0) >= 6 && st.gift_sent) return true;
  return false;
}

