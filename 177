const PACING_DELAY = {
  morning: [2000,  5000],
  day:     [1500,  4000],
  prime:   [1000,  3000],
  late:    [4000,  9000],
  quiet:   [8000, 20000],
};

function getPacingDelayMs(slot, textLen) {
  const [lo, hi] = PACING_DELAY[slot] || PACING_DELAY["day"];
  let ms = randInt(lo, hi);
  if (textLen > 180) ms += randInt(800, 1800);
  return ms;
}



