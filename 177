// ===============================
// LIVE MODE (delay umano)
// ===============================
// In produzione imposta env.LIVE_MODE="1" (wrangler vars / dashboard).
// In test lascialo vuoto o "0" per risposte rapide.
function isLiveMode(env, st) {
  if (st && typeof st._live_mode === "boolean") return st._live_mode;
  const v = (env && env.LIVE_MODE != null) ? String(env.LIVE_MODE) : "";
  return v === "1" || v.toLowerCase() === "true";
}

function clamp(n, a, b){ return Math.max(a, Math.min(b, n)); }

// Delay proporzionale al testo, con jitter
function humanDelayMs(text, env, st) {
  if (!isLiveMode(env, st)) return 0;
  const len = String(text || "").length;
  const base = randInt(3500, 7500);          // 3.5-7.5s
  const perChar = len * randFloat(28, 55);   // 28-55ms per char
  const extra = randInt(0, 1800);            // jitter
  return clamp(Math.round(base + perChar + extra), 2500, 22000);
}

// Spezza messaggi lunghi in 2 parti (effetto umano su Messenger)
function splitHuman(text) {
  const t = String(text || "").trim();
  if (t.length <= 90) return [t];
  // prova a spezzare su ". " o \"\n\"
  let cut = t.indexOf(". ");
  if (cut > 35 && cut < 120) {
    return [t.slice(0, cut+1).trim(), t.slice(cut+2).trim()];
  }
  cut = t.indexOf("\n");
  if (cut > 35 && cut < 140) {
    return [t.slice(0, cut).trim(), t.slice(cut+1).trim()];
  }
  // fallback: metà circa su spazio
  const mid = Math.floor(t.length * 0.55);
  let s = t.lastIndexOf(" ", mid);
  if (s < 30) s = mid;
  return [t.slice(0, s).trim(), t.slice(s).trim()];
}

function randInt(a,b){ return a + Math.floor(Math.random() * (b-a+1)); }
function randFloat(a,b){ return a + Math.random() * (b-a); }

// Enqueue SEND_TEXT con delay umano (cron)
function enqueueHumanText(st, env, text, minExtraMs=0) {
  const parts = splitHuman(text);
  const tsNow = Date.now();
  let at = Date.now() + minExtraMs + humanDelayMs(parts[0], env, st);
  enqueueAction(st, "SEND_TEXT", at, { text: parts[0] });
  if (parts.length > 1 && parts[1]) {
    at = at + randInt(2200, 5200) + humanDelayMs(parts[1], env, st);
    enqueueAction(st, "SEND_TEXT", at, { text: parts[1] });
  }
}


