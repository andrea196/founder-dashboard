/**
 * Gestisce invio/reuse link per qualsiasi offer con:
 * - Reuse TID entro finestra
 * - Limite resend (default 2)
 * - Anti-duplicazione
 * - Micro-pressure automatico
 * 
 * @param {string} psid - User ID
 * @param {object} st - State object
 * @param {string} offerKey - "t1"|"t2"|"t3"|"feet1"|"feet2"
 * @param {function} buildFn - async (psid, tier, env) => url
 * @param {object} options - Configuration
 * @param {number} options.windowMs - Durata finestra ms (default 90000)
 * @param {number} options.resendCap - Max resend (default 2)
 * @param {number} options.pressureDelayMin - Min pressure delay ms (default 30000)
 * @param {number} options.pressureDelayMax - Max pressure delay ms (default 45000)
 * @param {string} options.closedMessage - Messaggio quando limite raggiunto
 * @param {array} options.pressureMessages - Array messaggi pressure
 * @param {object} env - Environment bindings
 * @returns {object} { sent, reused?, limitReached?, url?, tid?, error? }
 */
// -----------------------------------------------------------------------------
// V66 SAFE: T1 AWAIT_PAYMENT link handling (window 90s + REENTRY +20% once)
// Message-driven (NO cron dependency). Works for any "link" request while awaiting payment.
// -----------------------------------------------------------------------------
async function handleAwaitPaymentT1LinkRequest(psid, st, env) {
  const now = Date.now();

  // V67 FIX: se reentry_penalty_t1=true (finestra già scaduta da CRON), tratta come windowExpired
  // In questo caso t1_window_expires_at potrebbe essere già stata azzerata dal CRON
  if (st.reentry_penalty_t1 && !st.reentry_premium_used_t1 && !st.reentry_premium_used) {
    console.log("🔥 V67: T1 reentry_penalty attiva → REENTRY diretto senza check finestra");
    await invalidatePreviousTid(env, st.t1_active_tid || st.last_t1_tid);
    const linkReentry = await buildTrackedGatewayUrl(psid, "tier1_reentry", env, false);
    if (linkReentry) {
      await fbSend(psid, linkReentry, env);
      console.log("✅ V67: T1 REENTRY link sent (penalty path)");
      // V141: telemetria reentry link_sent (side-effect only, non blocca flusso)
      try {
        if (env.METRICS_KV) {
          const _day = getRomeDayString();
          const _pfx = `m:${_day}:`;
          await kvIncr(env, _pfx + "reentry_link_sent_total", 1);
          await kvIncr(env, _pfx + "reentry_link_sent_tier1_reentry", 1);
        }
      } catch (_e) { console.log("[METRICS] reentry link_sent incr failed", String(_e)); }
    }
    const reentryTidMatch = linkReentry && linkReentry.match(/(t_[A-Za-z0-9]{16,})/);
    st.t1_active_tid = reentryTidMatch ? reentryTidMatch[1] : null;
    st.last_t1_tid   = st.t1_active_tid;
    await saveStateSafe(psid, st, env);
    return { kind: "reentry_penalty", withinWindow: false };
  }

  // Arm window ONCE (do not refresh on resend)
  if (!st.t1_window_expires_at) {
    st.t1_window_expires_at = now + (OFFER_CONFIGS.t1?.window || 90000);
  }

  const expires = Number(st.t1_window_expires_at);
  const withinWindow = expires && now < expires;
  const windowExpired = expires && now >= expires;

  // Tier-specific reentry flag (back-compat with old global flag)
  const reentryUsed = !!(st.reentry_premium_used_t1 || st.reentry_premium_used);

  console.log(`⏱️ T1_WINDOW: within=${withinWindow} expired=${windowExpired} expires=${expires ? new Date(expires).toISOString() : 'null'} reentryUsed=${reentryUsed}`);

  // Metrics: count every request; count resend inside window
  st.t1_request_count = (st.t1_request_count || 0) + 1;
  if (withinWindow) st.t1_resend_count = (st.t1_resend_count || 0) + 1;
  await saveStateSafe(psid, st, env);

  // CASE 1: within window -> reuse normal link engine
  if (withinWindow) {
    console.log("🔥 V67: T1 within window -> normal reuse");
    // prevent duplicate SEND_TIER1 jobs
    st.timed_queue = Array.isArray(st.timed_queue) ? st.timed_queue : [];
    const oldTier1Count = st.timed_queue.filter(item => item.action === "SEND_TIER1").length;
    st.timed_queue = st.timed_queue.filter(item => item.action !== "SEND_TIER1");
    if (oldTier1Count > 0) console.log(`🔥 V67: Removed ${oldTier1Count} SEND_TIER1 from queue`);

    // V67 FIX: se esiste già un link reentry attivo (t1_active_tid da un precedente send reentry)
    // riusalo invece di generarne uno nuovo base — evita di mostrare prezzo normale dopo reentry inviato
    const existingUrl = st.t1_last_url || st.last_t1_link_url || null;
    const existingTid = st.t1_active_tid || st.last_t1_tid || null;
    if (existingTid && existingUrl && !reentryUsed) {
      await fbSend(psid, existingUrl, env);
      console.log(`♻️ V67: T1 reuse existing link (tid: ${existingTid})`);
      try { if (env.METRICS_KV) await kvIncr(env, `m:${getRomeDayString()}:t1_link_sent`, 1); } catch (_e) {}
      await saveStateSafe(psid, st, env);
      return { kind: "reuse", withinWindow: true };
    }

    await sendOrReuseOfferLink(psid, st, "t1", buildTrackedGatewayUrl, {}, env);
    return { kind: "normal", withinWindow: true };
  }

  // CASE 2: expired + not used -> send REENTRY premium (+20%) once
  if (windowExpired && !reentryUsed) {
    console.log("🔥 V67: T1 window expired -> REENTRY +20% (first time)");
    // V66: Invalida TID base precedente → utente non può tornare al link vecchio
    await invalidatePreviousTid(env, st.t1_active_tid || st.last_t1_tid);
    const linkReentry = await buildTrackedGatewayUrl(psid, "tier1_reentry", env, false); // tier1_reentry nel TID
    if (linkReentry) {
      await fbSend(psid, linkReentry, env);
      console.log("✅ V67: T1 REENTRY link sent (no extra text)");
      try {
        if (env.METRICS_KV) {
          const _d = getRomeDayString();
          await kvIncr(env, `m:${_d}:reentry_link_sent_total`, 1);
          await kvIncr(env, `m:${_d}:reentry_link_sent_tier1_reentry`, 1);
        }
      } catch (_e) {}
    }
    // Salva nuovo TID come attivo — MA non setta reentry_premium_used_t1 qui!
    // Il flag viene settato dal webhook quando Whop conferma il pagamento tier1_reentry
    const reentryTidMatch = linkReentry && linkReentry.match(/(t_[A-Za-z0-9]{16,})/);
    st.t1_active_tid  = reentryTidMatch ? reentryTidMatch[1] : null;
    st.last_t1_tid    = st.t1_active_tid; // backward compat
    // V67 FIX: NON settare reentry_premium_used_t1 = true qui
    // Settarlo ora causa: se l'utente chiede di nuovo il link → CASE 3 (chiusura) invece di riusare il reentry
    // Il flag viene settato solo dal webhook → case "tier1_reentry" in switch(finalTier)
    await saveStateSafe(psid, st, env);
    return { kind: "reentry", withinWindow: false };
  }

  // CASE 3: reentry already used -> cold closure
  if (reentryUsed) {
    console.log("🔥 V66: T1 reentry already used -> closure");
    const closureMessages = [
      "Chiuso.",
      "Non lo tengo aperto all'infinito."
    ];
    const chosen = closureMessages[Math.floor(Math.random() * closureMessages.length)];
    await fbSend(psid, chosen, env);
    await saveStateSafe(psid, st, env);
    return { kind: "closed", withinWindow: false };
  }

  // Fallback (shouldn't happen): normal
  await sendOrReuseOfferLink(psid, st, "t1", buildTrackedGatewayUrl, {}, env);
  return { kind: "fallback", withinWindow: false };
}

async function sendOrReuseOfferLink(
  psid,
  st,
  offerKey,
  buildFn,
  options = {},
  env
) {
  // V66: Usa OFFER_CONFIGS come defaults, poi override con options
  const config = OFFER_CONFIGS[offerKey] || {};
  const {
    windowMs = config.window || 90000,
    resendCap = config.resendCap || 2,
    pressureDelayMin = config.pressure ? config.pressure - 10000 : 30000,
    pressureDelayMax = config.pressure ? config.pressure + 10000 : 45000,
    closedMessage = "Il link è già lì. Sta a te ora 😉",
