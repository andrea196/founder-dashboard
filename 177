 */
function beginOffer(st, kind, queue) {
  st.offer_epoch = (st.offer_epoch || 0) + 1;
  st.offer_kind  = kind;
  st.offer_sent_at = Date.now();
  // Pulisci follow-up vecchi dalla queue passata
  if (Array.isArray(queue)) {
    const before = queue.length;
    const cleaned = queue.filter(item => !FOLLOWUP_ACTIONS.has(item.action));
    queue.length = 0;
    cleaned.forEach(x => queue.push(x));
    if (queue.length < before) {
      console.log(`✅ V111: beginOffer(${kind}) epoch=${st.offer_epoch} — rimossi ${before - queue.length} followup vecchi`);
    }
  }
}

/**
 * guardFollowup: gate unico da chiamare PRIMA di inviare qualsiasi follow-up.
 * Ritorna { send: bool, reschedule: bool, rescheduleAt: number }
 * @param {object} st   - user state
 * @param {object} item - job dalla timed_queue (deve avere item.offer_epoch se disponibile)
 */
function guardFollowup(st, item) {
  const now = Date.now();

  // 1. Epoch mismatch: job schedulato per un'offerta diversa da quella corrente → SCARTA
  if (item.offer_epoch !== undefined && item.offer_epoch !== st.offer_epoch) {
    console.log(`⏭️  V111: followup SCARTATO (epoch mismatch: job=${item.offer_epoch} state=${st.offer_epoch})`);
    return { send: false, reschedule: false };
  }

  // 2. Utente ha scritto di recente → SLITTAMENTO automatico (non scarta, ripianifica)
  const silenceNeeded = 45000; // 45s di silenzio richiesti prima di inviare
  if (st.last_user_msg_at && (now - st.last_user_msg_at) < silenceNeeded) {
    const rescheduleAt = st.last_user_msg_at + silenceNeeded;
    console.log(`⏳ V111: followup SLITTA — user ha scritto ${Math.round((now - st.last_user_msg_at)/1000)}s fa → ripianifica a +${Math.round((rescheduleAt - now)/1000)}s`);
    return { send: false, reschedule: true, rescheduleAt };
  }

  // 3. Tutto ok → via libera
  return { send: true, reschedule: false };
}

