// ---------- Objection Detection + Closing (PRO) ----------
function detectObjectionType(text = "") {
  const t = norm(text);

  // CONTENT / QUALITY DISAPPOINTMENT — materiale non piace, non è quello che si aspettava
  // Va prima di MONEY per catturare "non vale quei soldi" come delusione, non solo prezzo
  // V154 FIX: varianti senza accento (è→e, più→piu, qualità→qualita) per utenti che scrivono senza accento
  if (/(non mi ([eè] |)piaciut|non mi aspettav|mi aspettav(o|a) di (pi[uù]|meglio|altro)|non [eè] quello che|pensavo (ci fosse|fosse|ci fossero)|delusione|deluso|delusa|non vale|troppo poco|scarso|scarsa|qualit[aà] bas|non c[''][eè] gran|niente di (speciale|che|nuovo)|visto di meglio|ho visto meglio|gratis (trovi|si trova|ce n'[eè]) di (meglio|pi[uù]))/i.test(t)) return "CONTENT";

  // VALUE — non convinto che valga il prezzo (diverso da CONTENT: non ha visto il materiale)
  if (/(ne vale la pena|vale la pena|conviene|conveniente|vale davvero|giustifica|giustifichi|rapporto qualit[aà]|per quei soldi)/i.test(t)) return "VALUE";

  // MONEY / PRICE
  if (/(non pago|costa|costoso|prezzo|soldi|troppo)/i.test(t)) return "MONEY";

  // TRUST / SAFETY
  if (/(scam|truffa|mi fido|non mi fido|sicuro|garanzia|è vero\?|posso fidarmi)/i.test(t)) return "TRUST";

  // TIME / STALL
  if (/(ci penso|più tardi|dopo|domani|vediamo|in seguito|non ora)/i.test(t)) return "TIME";

  // FREE
  if (/(gratis|free|senza pagare)/i.test(t)) return "FREE";

  // BOT / AI DOUBT — rafforzato: insistenza che sia un bot/AI
  if (/(sei (un |)bot|sei (una |)ia|sei (un |)ai|sei artificiale|sei programmata|parli come (un |)robot|risposte (pre|già) (impostate|programmate|scripted)|non sei (vera|reale|umana)|stai leggendo (da |)uno script|rispondi (sempre |)uguale|le stesse risposte)/i.test(t)) return "BOT";

  // HARD NO (soft refusal)
  if (/^(no|non voglio|lascia stare|niente)$/i.test(t)) return "NO";

  return null;
}

function bumpObjection(st, type) {
  st.objection_count = (st.objection_count || 0) + 1;
  st.postLinkState = "OBJECTION";
  st.objectionType = type || null;
