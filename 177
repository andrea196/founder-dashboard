function normalizeToken(tok){
  tok = String(tok||"").toLowerCase();
  // Collassa ripetizioni (es: "ciaooo" -> "ciaoo")
  tok = tok.replace(/(.)\1{2,}/g, "$1$1");
  // Rimuovi caratteri non lettera/numero
  tok = tok.replace(/[^a-zàèéìòù0-9]/gi, "");
  return tok;
}

function correctToken(tok){
  const t = normalizeToken(tok);
  if (!t || t.length < 4) return tok; // non tocchiamo parole molto corte
  // se è già nel vocabolario, ok
  if (KEYWORD_VOCAB_IT.includes(t)) return tok;
  let best = null, bestD = 999;
  for (const w of KEYWORD_VOCAB_IT) {
    // limita confronti per lunghezze simili
    if (Math.abs(w.length - t.length) > 2) continue;
    const d = levenshtein(t, w);
    if (d < bestD) { bestD = d; best = w; }
    if (bestD === 1) break;
  }
  // correzione solo se molto vicina (1-2 edit)
  if (best && bestD <= 2) {
    // preserva maiuscola iniziale se presente
    const isCap = /^[A-ZÀÈÉÌÒÙ]/.test(tok);
    return isCap ? (best.charAt(0).toUpperCase() + best.slice(1)) : best;
  }
  return tok;
}

function autocorrectTextIT(text){
  const s = String(text||"");
  // Split conservando spazi/punteggiatura
  return s.split(/(\s+)/).map(part => {
    if (/^\s+$/.test(part)) return part;
    // correzione parola per parola (mantieni punteggiatura attaccata)
    return part.split(/(\b)/).map(x => (/^[\wÀÈÉÌÒÙàèéìòù]+$/.test(x) ? correctToken(x) : x)).join("");
  }).join("");
}
