// Genera firma HMAC-SHA256 per URL R2 time-limited
// Format: first 16 chars of hex(HMAC-SHA256(key + ":" + day, CONTENT_SECRET))
async function _signR2Auth(key, day, env) {
  const secret = env.CONTENT_SECRET || "dev-secret-change-me";
  const msg = `${key}:${day}`;
  const enc = new TextEncoder();
  const k = await crypto.subtle.importKey("raw", enc.encode(secret), { name: "HMAC", hash: "SHA-256" }, false, ["sign"]);
  const sig = await crypto.subtle.sign("HMAC", k, enc.encode(msg));
  const hex = Array.from(new Uint8Array(sig)).map(b => b.toString(16).padStart(2, "0")).join("");
  return hex.slice(0, 24); // 24 chars = sicuro e compatto
}

