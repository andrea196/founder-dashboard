// --- SEMPLIFICAZIONE DM ---
function simplifyDM(t = "") {
  t = t.trim();

  t = t
    .replace(/\bNon è che\s+/gi, "")
    .replace(/\bDiciamo che\s+/gi, "")
    .replace(/\bIn realtà\s*,?\s*/gi, "In realtà ")
    .replace(/\bComunque\s*,?\s*/gi, "Comunque ")
    .replace(/\bPertanto\b/gi, "")
    .replace(/\bDunque\b/gi, "")
    .replace(/\bQuindi\b/gi, "");

  const commas = (t.match(/,/g) || []).length;
  if (commas >= 3) {
    const parts = t.split(",");
    const first = parts.slice(0, 2).join(",").trim();
    let rest = parts.slice(2).join(",").trim();
    if (rest) t = `${first}. ${rest}`;
  }

  return t.trim();
}

// --- TAGLIO PER DM ---
function trimForDM(t = "", maxLen = 170) {
  if (t.length <= maxLen) return t;

  const cut = t.slice(0, maxLen);
  const lastStop = Math.max(
    cut.lastIndexOf("."),
    cut.lastIndexOf("!"),
    cut.lastIndexOf("?")
  );

  if (lastStop > 60) {
    return cut.slice(0, lastStop + 1).trim();
  }

  return cut.trim() + "...";
}

