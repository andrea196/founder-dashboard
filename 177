async function handleRequest(req, env, ctx) {

    const url = new URL(req.url);
    const path = "/" + url.pathname.replace(/^\/+/, ""); // V120c: normalizza doppio slash (//webhook → /webhook)

    // V111: Version endpoint — PRIMO assoluto, nessuna auth, nessun blocco possibile
    if (path === "/api/version" && req.method === "GET") {
      return corsResponse(JSON.stringify({ version: "V174" }), { status: 200, headers: { "Content-Type": "application/json" } });
    }

    // ========================================================================
    // V175 — CONTENT DELIVERY ROUTES
    // GET /c/<tid>    — pagina contenuti per utente pagato
    // GET /r2/<key>   — proxy file R2 con auth HMAC time-limited
    // ========================================================================

    // GET /c/<tid> — content delivery page
    if (req.method === "GET" && path.startsWith("/c/")) {
      const cTid = path.slice(3).split("/")[0];
      if (!cTid) return new Response("Not found", { status: 404 });
      try {
        const cResolved = await resolvePsidFromTid(env, cTid);
        if (!cResolved || !cResolved.psid) return new Response("Link non valido o scaduto.", { status: 410 });
        const cTier = cResolved.tier || "";
        // Sicurezza: solo TID con prefix "c_" aprono questa route
        if (!cTier.startsWith("c_")) {
          console.warn(`⚠️ V175: /c/ blocked — tier="${cTier}" non ha prefix c_`);
          return new Response("Accesso non autorizzato.", { status: 403 });
        }
        if (cResolved.superseded) return new Response("Link scaduto.", { status: 410 });
        const cPsid = cResolved.psid;
        // Verifica pagamento su FUNNEL_STATE
        const cFunnelRaw = await env.FUNNEL_STATE?.get(`user:${cPsid}`).catch(() => null);
        const cFunnel = cFunnelRaw ? JSON.parse(cFunnelRaw) : {};
        const cPaidFlag = _tierToPaidFlag(cTier);
        const cPaid = cPaidFlag ? !!cFunnel[cPaidFlag] : false;
        if (!cPaid) {
          // Genera URL checkout per il tier corrispondente
          const cBaseTier = cTier.replace("c_", "");
          const cGwUrl = `${getPublicBaseUrl(env)}/gateway/main?tid=${cTid}&tier=${cBaseTier}`;
          return new Response(_renderNoAccessHTML(cBaseTier, cGwUrl), {
            status: 403,
            headers: { "Content-Type": "text/html;charset=utf-8", "Cache-Control": "no-store" }
          });
        }
        // Lista file R2
        const cPrefix = _tierToR2Prefix(cTier);
        let cFiles = { foto: [], video: [], altri: [] };
        if (env.CONTENT_BUCKET && cPrefix) {
          const cBaseUrl = getPublicBaseUrl(env);
          const cNow = Math.floor(Date.now() / 86400000);
          const listFoto  = await env.CONTENT_BUCKET.list({ prefix: `${cPrefix}foto/`  }).catch(() => null);
          const listVideo = await env.CONTENT_BUCKET.list({ prefix: `${cPrefix}video/` }).catch(() => null);
          if (listFoto?.objects)  cFiles.foto  = listFoto.objects.map(o  => ({ key: o.key,  name: o.key.split("/").pop(),  size: o.size,  auth: _signR2Auth(o.key, cNow, env) }));
          if (listVideo?.objects) cFiles.video = listVideo.objects.map(o => ({ key: o.key,  name: o.key.split("/").pop(),  size: o.size,  auth: _signR2Auth(o.key, cNow, env) }));
          // Filtra file zero-byte e file di sistema
          const _flt = f => f.size > 0 && !f.name.startsWith(".");
          cFiles.foto  = cFiles.foto.filter(_flt);
          cFiles.video = cFiles.video.filter(_flt);
        }
        const cHtml = _renderContentHTML(cTier, cFiles, env);
        return new Response(cHtml, {
          status: 200,
          headers: { "Content-Type": "text/html;charset=utf-8", "Cache-Control": "no-store, no-cache" }
        });
      } catch (_ce) {
        console.error("❌ V175: /c/ error:", _ce.message);
        return new Response("Errore interno.", { status: 500 });
      }
    }

    // GET /r2/<key> — proxy file R2 autenticato con HMAC time-limited
    if (req.method === "GET" && path.startsWith("/r2/")) {
      const rKey = decodeURIComponent(path.slice(4));
      const rAuth = url.searchParams.get("auth") || "";
      const rDay  = parseInt(url.searchParams.get("d") || "0", 10);
      if (!rKey || !rAuth || !rDay) {
        return new Response("Accesso non autorizzato.", { status: 403 });
      }
      // Verifica firma HMAC — accetta giorno corrente e giorno precedente (finestra ~48h)
      const rNowDay = Math.floor(Date.now() / 86400000);
      const rOk = (rDay === rNowDay || rDay === rNowDay - 1) &&
                  rAuth === _signR2Auth(rKey, rDay, env);
      if (!rOk) return new Response("Link scaduto o non valido.", { status: 403 });
      if (!env.CONTENT_BUCKET) return new Response("Storage non configurato.", { status: 503 });
      try {
        const rObj = await env.CONTENT_BUCKET.get(rKey);
        if (!rObj) return new Response("File non trovato.", { status: 404 });
        const rExt = rKey.split(".").pop().toLowerCase();
        const rMime = { jpg:"image/jpeg", jpeg:"image/jpeg", png:"image/png", gif:"image/gif",
                        webp:"image/webp", mp4:"video/mp4", mov:"video/quicktime",
                        avi:"video/x-msvideo", pdf:"application/pdf" }[rExt] || "application/octet-stream";
        const rName = rKey.split("/").pop();
        return new Response(rObj.body, {
          status: 200,
          headers: {
            "Content-Type": rMime,
            "Content-Disposition": `inline; filename="${rName}"`,
            "Cache-Control": "private, max-age=3600",
            "X-Content-Type-Options": "nosniff",
          }
        });
      } catch (_re) {
        console.error("❌ V175: /r2/ error:", _re.message);
        return new Response("Errore caricamento file.", { status: 500 });
      }
    }

    // ========================================================================
    // V71 — TEST ENDPOINTS (solo se WHOP_TEST_SECRET configurato)
    // ========================================================================

    // GET /api/debug-state?psid=XXX — alias di test-state per compatibilità test suite V109
    // Risponde con { chatState: {...} } invece di { state: {...} }
    if (path === "/api/debug-state" && req.method === "GET") {
      const testKey = req.headers.get("X-Test-Key") || url.searchParams.get("key");
      const cronKey = req.headers.get("X-Cron-Token") || url.searchParams.get("cron_token");
      const isAuthed = (env.WHOP_TEST_SECRET && testKey === env.WHOP_TEST_SECRET) ||
                       (env.CRON_DEBUG_TOKEN && cronKey === env.CRON_DEBUG_TOKEN);
      if (!isAuthed) {
        return corsResponse(JSON.stringify({ error: "Unauthorized" }), { status: 401, headers: { "Content-Type": "application/json" } });
      }
      const psid = url.searchParams.get("psid");
      if (!psid) return corsResponse(JSON.stringify({ error: "Missing psid" }), { status: 400, headers: { "Content-Type": "application/json" } });
      const kv = getStateKV(env);
      const stateRaw = await kv.get(`state:${psid}`).catch(() => null);
      const chatState = stateRaw ? JSON.parse(stateRaw) : null;
      return corsResponse(JSON.stringify({ chatState, ts: Date.now() }), { status: 200, headers: { "Content-Type": "application/json" } });
    }

    // GET /api/test-state?psid=XXX — legge state + log da KV
    if (path === "/api/test-state" && req.method === "GET") {
      const testKey = req.headers.get("X-Test-Key") || url.searchParams.get("key");
      if (!env.WHOP_TEST_SECRET || testKey !== env.WHOP_TEST_SECRET) {
        return corsResponse(JSON.stringify({ error: "Unauthorized" }), { status: 401, headers: { "Content-Type": "application/json" } });
      }
      const psid = url.searchParams.get("psid");
      if (!psid) return corsResponse(JSON.stringify({ error: "Missing psid" }), { status: 400, headers: { "Content-Type": "application/json" } });

      const kv = getStateKV(env);
      const [stateRaw, logsRaw, funnelRaw] = await Promise.all([
        kv.get(`state:${psid}`).catch(() => null),
        kv.get(`testlog:${psid}`).catch(() => null),
        env.FUNNEL_STATE?.get(`user:${psid}`).catch(() => null),
      ]);

      // V119 FIX: upsert — se lo state non esiste ancora, crea e salva uno state fresco.
      // Garantisce che Warm-State non fallisca mai per problemi di KV consistency
      // o per crash silenzioso in handleText. Il test-state diventa idempotente.
      let stateObj = stateRaw ? JSON.parse(stateRaw) : null;
      if (!stateObj) {
        stateObj = initState(psid);
        stateObj.reset_epoch = Date.now();
        await kv.put(`state:${psid}`, JSON.stringify(stateObj)).catch(() => null);
        console.log(`✅ V119: test-state upsert — stato fresco creato per ${psid}`);
      }

      return corsResponse(JSON.stringify({
        state:  stateObj,
        funnel: funnelRaw ? JSON.parse(funnelRaw) : null,
        logs:   logsRaw   ? JSON.parse(logsRaw)   : [],
        ts: Date.now(),
      }), { status: 200, headers: { "Content-Type": "application/json" } });
    }

    // POST /api/test-reentry — simula eventi reentry per test dashboard (solo admin)
    // Body: { "action": "link_sent"|"paid"|"reset", "tier": "tier1_reentry"|..., "cents": 5999 }
    if (path === "/api/test-reentry" && req.method === "POST") {
      if (!isAdmin) return corsResponse(JSON.stringify({ error: "Unauthorized" }), { status: 401, headers: { "Content-Type": "application/json" } });
      if (!env.METRICS_KV) return corsResponse(JSON.stringify({ error: "METRICS_KV not configured" }), { status: 500, headers: { "Content-Type": "application/json" } });

      const body = await req.json().catch(() => ({}));
      const action = body?.action;
      const tier   = body?.tier;
      const cents  = Number(body?.cents) || 0;

      const validTiers = ["tier1_reentry","tier2_reentry","tier3_reentry","feet1_reentry","feet2_reentry"];
      const day   = getRomeDayString();
      const pfx   = `m:${day}:`;

      // RESET: cancella tutte le chiavi reentry di oggi
      if (action === "reset") {
        const keysToDelete = [
          pfx + "reentry_link_sent_total",
          pfx + "reentry_paid_total",
          pfx + "reentry_revenue_total_cents",
          ...validTiers.flatMap(t => [
            pfx + `reentry_link_sent_${t}`,
            pfx + `reentry_paid_${t}`,
            pfx + `reentry_revenue_${t}_cents`,
          ]),
        ];
        await Promise.all(keysToDelete.map(k => env.METRICS_KV.delete(k).catch(() => {})));
        console.log("[TEST-REENTRY] reset completato per", day);
        return corsResponse(JSON.stringify({ ok: true, action: "reset", day, deleted: keysToDelete.length }), { status: 200, headers: { "Content-Type": "application/json" } });
      }

      // Validazione tier per link_sent e paid
      if (!validTiers.includes(tier)) {
        return corsResponse(JSON.stringify({ error: `tier non valido. Valori ammessi: ${validTiers.join(", ")}` }), { status: 400, headers: { "Content-Type": "application/json" } });
      }

      if (action === "link_sent") {
        await kvIncr(env, pfx + "reentry_link_sent_total", 1);
        await kvIncr(env, pfx + `reentry_link_sent_${tier}`, 1);
        console.log(`[TEST-REENTRY] link_sent ${tier} day=${day}`);
        return corsResponse(JSON.stringify({ ok: true, action, tier, day }), { status: 200, headers: { "Content-Type": "application/json" } });
      }

      if (action === "paid") {
        const safeCents = Number.isFinite(cents) && cents > 0 ? cents : 0;
        await kvIncr(env, pfx + "reentry_paid_total", 1);
        await kvIncr(env, pfx + `reentry_paid_${tier}`, 1);
        if (safeCents > 0) {
          await kvIncr(env, pfx + "reentry_revenue_total_cents", safeCents);
          await kvIncr(env, pfx + `reentry_revenue_${tier}_cents`, safeCents);
        }
        console.log(`[TEST-REENTRY] paid ${tier} cents=${safeCents} day=${day}`);
        return corsResponse(JSON.stringify({ ok: true, action, tier, cents: safeCents, day }), { status: 200, headers: { "Content-Type": "application/json" } });
      }

      return corsResponse(JSON.stringify({ error: "action non valida. Usa: link_sent | paid | reset" }), { status: 400, headers: { "Content-Type": "application/json" } });
    }

    // POST /api/clear-test — cancella state + log per PSID (reset tra test)
    if (path === "/api/clear-test" && req.method === "POST") {
      const testKey = req.headers.get("X-Test-Key") || url.searchParams.get("key");
      if (!env.WHOP_TEST_SECRET || testKey !== env.WHOP_TEST_SECRET) {
        return corsResponse(JSON.stringify({ error: "Unauthorized" }), { status: 401, headers: { "Content-Type": "application/json" } });
      }
      let _cb = {}; try { const _ct = await req.text(); _cb = _ct ? JSON.parse(_ct) : {}; } catch(e) { _cb = {}; }
      const psid = _cb.psid || url.searchParams.get("psid");
      if (!psid) return corsResponse(JSON.stringify({ error: "Missing psid" }), { status: 400, headers: { "Content-Type": "application/json" } });

      const kv = getStateKV(env);
      await Promise.all([
        kv.delete(`state:${psid}`).catch(() => null),
        kv.delete(`testlog:${psid}`).catch(() => null),
        env.FUNNEL_STATE?.delete(`user:${psid}`).catch(() => null),
      ]);
      // V119 FIX: Scrivi SUBITO uno state fresco dopo il delete.
      // Problema: Cloudflare KV ha eventual consistency — dopo un delete,
      // una write immediata (da Send-Msg webhook) potrebbe non essere visibile
      // per una lettura successiva entro 2s (Warm-State timeout).
      // Soluzione: /api/clear-test crea lo state fresco DIRETTAMENTE via KV write
      // (stesso processo, stessa connessione → visibilità garantita).
      // Warm-State troverà lo state fresco in Get-State senza dipendere dal webhook.
      const freshSt = initState(psid);
      freshSt.reset_epoch = Date.now();
      await kv.put(`state:${psid}`, JSON.stringify(freshSt)).catch(() => null);
      console.log(`✅ V119: clear-test + warm state per ${psid}`);
      return corsResponse(JSON.stringify({ ok: true, psid, state: freshSt }), { status: 200, headers: { "Content-Type": "application/json" } });
    }

    // ========================================================================
    // V94 FIX: POST /api/inject-state — sovrascrive campi specifici dello state
    // Scrive su CHAT_KV (state:{psid}) + sync paid flags su FUNNEL_STATE (user:{psid})
    // ========================================================================
    if (path === "/api/inject-state" && req.method === "POST") {
      const testKey = req.headers.get("X-Test-Key") || url.searchParams.get("key");
      if (!env.WHOP_TEST_SECRET || testKey !== env.WHOP_TEST_SECRET) {
        return corsResponse(JSON.stringify({ error: "Unauthorized" }), { status: 401, headers: { "Content-Type": "application/json" } });
      }
      let _ib = {}; try { const _it = await req.text(); _ib = _it ? JSON.parse(_it) : {}; } catch(e) { _ib = {}; }
      const psid = _ib.psid || url.searchParams.get("psid");
      const patch = _ib.patch || _ib.state || {}; // V138 FIX: test suite invia body.state, non body.patch
      if (!psid) return corsResponse(JSON.stringify({ error: "Missing psid" }), { status: 400, headers: { "Content-Type": "application/json" } });

      const kv = getStateKV(env);
      // 1. Leggi stato attuale
      const raw = await kv.get(`state:${psid}`).catch(() => null);
      const st = raw ? JSON.parse(raw) : initState(psid);

      // 2. Applica patch al chat state (Object.assign rispetta i null)
      Object.assign(st, patch);
      st.psid = psid;
      await kv.put(`state:${psid}`, JSON.stringify(st));

      // 3. CRITICO: sync paid flags + reentry window fields anche su FUNNEL_STATE
      //    Altrimenti V18 trigger block + gateway checkReentryGw + create-checkout enforceReentry leggono dati vecchi
      //    V174 FIX: aggiunto sync di tutti i campi che create-checkout legge da FUNNEL_STATE per enforceReentry
      const PAID_FIELDS = ["tier1_paid","tier2_paid","tier3_paid","vip_paid","feet_tier1_paid","feet_tier2_paid"];
      // V174: Campi finestra reentry + flag premium usati da create-checkout (enforceReentry legge FUNNEL_STATE)
      const REENTRY_FIELDS = [
        "t1_window_expires_at","t2_window_expires_at","t3_window_expires_at",
        "feet1_window_expires_at","feet2_window_expires_at",
        "t1_last_sent_at","t2_last_sent_at","t3_last_sent_at",
        "feet1_last_sent_at","feet2_last_sent_at",
        "reentry_premium_used","reentry_premium_used_t1","reentry_premium_used_t2",
        "reentry_premium_used_t3","reentry_premium_used_feet1","reentry_premium_used_feet2",
        "reentry_penalty_t1","reentry_used_t1",
        "reset_epoch",
      ];
      const ALL_SYNC_FIELDS = [...PAID_FIELDS, ...REENTRY_FIELDS];
      const hasSyncPatch = ALL_SYNC_FIELDS.some(f => f in patch);
      if (hasSyncPatch && env.FUNNEL_STATE) {
        const funnelRaw = await env.FUNNEL_STATE?.get(`user:${psid}`).catch(() => null);
        const funnel = funnelRaw ? JSON.parse(funnelRaw) : {};
        // Paid fields: cast a boolean
        PAID_FIELDS.forEach(f => { if (f in patch) funnel[f] = !!patch[f]; });
        // Reentry fields: copia valore raw (numeri timestamp, boolean flags)
        REENTRY_FIELDS.forEach(f => { if (f in patch) funnel[f] = patch[f]; });
        await env.FUNNEL_STATE?.put(`user:${psid}`, JSON.stringify(funnel));
        console.log(`✅ V174: inject-state sync FUNNEL_STATE per ${psid}`, ALL_SYNC_FIELDS.filter(f => f in patch).map(f => `${f}=${patch[f]}`).join(", "));
      }

      console.log(`✅ V94: inject-state OK per ${psid} — patch fields: ${Object.keys(patch).join(", ")}`);
      return corsResponse(JSON.stringify({ ok: true, psid, fields: Object.keys(patch) }), { status: 200, headers: { "Content-Type": "application/json" } });
    }

    // V94 FIX: POST /api/inject-queue — aggiunge item direttamente in timed_queue
