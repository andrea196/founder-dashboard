/**
 * Carica state con error handling robusto
 * @returns {Object} State valido, mai undefined
 */
async function loadStateSafe(psid, env) {
  try {
    // Validazione input
    if (!psid || typeof psid !== 'string') {
      console.error(`Invalid psid: ${psid}`);
      return initState("INVALID_PSID");
    }
    
    // Validazione KV binding
    const kv = getStateKV(env);
    if (!kv) {
      console.error("KV binding not found");
      return initState(psid);
    }
    
    // Load from KV con timeout
    const raw = await Promise.race([
      kv.get(stateKey(psid)),
      new Promise((_, reject) => 
        setTimeout(() => reject(new Error("KV timeout")), 5000)
      )
    ]);
    
    // Caso 1: Nessun state esistente
    if (!raw) {
      console.log(`No state for ${psid}, initializing new`);
      return initState(psid);
    }
    
    // Caso 2: Parse JSON
    let st;
    try {
      st = JSON.parse(raw);
    } catch (parseError) {
      console.error(`JSON parse error for ${psid}:`, String(parseError));
      console.error(`Raw data: ${raw.substring(0, 100)}...`);
      return initState(psid); // Fallback a stato pulito
    }
    
    // Caso 3: Validazione struttura state
    if (!st || typeof st !== 'object') {
      console.error(`Invalid state type for ${psid}: ${typeof st}`);
      return initState(psid);
    }
    
    if (!st.psid) {
      console.error(`State missing psid field for ${psid}`);
      st.psid = psid; // Fix + continua
