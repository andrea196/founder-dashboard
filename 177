// ── V122: rescheduleAfterQuiet() — sposta un item alla fine delle quiet hours ──
// Sposta l'item a 07:31 Europe/Rome del mattino corrente (o domani se già passato).
// Non modifica payload, reason, o altri campi.
function rescheduleAfterQuiet(item, nowMs) {
  const now = nowMs || Date.now();
  const d = new Date(now);
  // Calcola 07:31 Europe/Rome → approxima con UTC offset (CET=+1, CEST=+2)
  // Usiamo Intl per trovare l'ora corrente a Roma, poi calcoliamo il delta
  try {
    const romeParts = new Intl.DateTimeFormat("it-IT", {
      timeZone: "Europe/Rome",
      hour: "2-digit", minute: "2-digit", hour12: false
    }).formatToParts(d);
    const romeH = parseInt(romeParts.find(p => p.type === "hour")?.value || "3", 10);
    const romeM = parseInt(romeParts.find(p => p.type === "minute")?.value || "0", 10);
    // Minuti mancanti a 07:31 da adesso
    const currentMin = romeH * 60 + romeM;
    const targetMin  = 7 * 60 + 31;
    const deltaMin   = targetMin > currentMin ? (targetMin - currentMin) : (1440 - currentMin + targetMin);
    const newAt = now + deltaMin * 60 * 1000;
    return { ...item, at: newAt, _quiet_rescheduled: true };
  } catch (e) {
    // Fallback: +5 ore
    return { ...item, at: now + 5 * 60 * 60 * 1000, _quiet_rescheduled: true };
  }
}

