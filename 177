  const msgCount = st.msg_count || 0;
  const lastStory = st.last_story_msg || 0;
  const storyCount = st.story_count || 0;
  
  if (msgCount - lastStory < 8) return false;
  if (eng >= 7 && storyCount < 15) return true;
  if (msgCount >= 15 && msgCount % 12 === 0) return true;
  
  return false;
}

function getStoryCategory(userMsg, st) {
  const n = norm(userMsg);
  
  if (n.match(/infanz|piccol|bambin|quando eri|da piccol/)) return "childhood";
  if (n.match(/adolescen|scuola|ragaz|lice|medie/)) return "teen";
  if (n.match(/amor|relazion|fidanzat|ex|cuore|ama/)) return "love";
  if (n.match(/sogn|desider|vogl|futur|sper/)) return "dreams";
  if (n.match(/crescit|cambi|evolv|impar|diventa/)) return "growth";
  if (n.match(/sent|emoz|trist|fel|paur|solo/)) return "emotional";
  
  return "emotional";
}

function getRandomStory(category, st) {
  const stories = {
    childhood: CHILDHOOD_STORIES,
    teen: TEEN_STORIES,
    love: LOVE_STORIES,
    dreams: DREAMS_DESIRES,
    emotional: EMOTIONAL_REVEALS,
    growth: GROWTH_STORIES,
  };
  
  const pool = stories[category] || EMOTIONAL_REVEALS;
  const revealed = st.revealed_stories || [];
  
  const available = pool.filter(s => !revealed.includes(s));
  
  if (available.length === 0) {
    const allStories = [
      ...CHILDHOOD_STORIES,
      ...TEEN_STORIES,
      ...LOVE_STORIES,
      ...DREAMS_DESIRES,
      ...EMOTIONAL_REVEALS,
      ...GROWTH_STORIES,
    ];
    
    const allAvailable = allStories.filter(s => !revealed.includes(s));
    
    if (allAvailable.length === 0) {
      st.revealed_stories = [];
      return pick(pool);
    }
    
    return pick(allAvailable);
  }
  
  return pick(available);
}

function markStoryRevealed(st, story) {
  if (!story) return;
  
  st.revealed_stories = st.revealed_stories || [];
  
  if (!st.revealed_stories.includes(story)) {
    st.revealed_stories.push(story);
  }
  
  if (st.revealed_stories.length > 30) {
    st.revealed_stories = st.revealed_stories.slice(-30);
  }
}

