// ---------- Sanitize + Limit ----------
function sanitizeGroq(txt) {
  let s = String(txt || "").trim();
  s = s.replace(/^(Luna:|LUNA:|Gabriella:|GABRIELLA:|Assistant:|AI:)\s*/i, "");
  s = stripUrls(s);
  // V78 FIX: blocca risposte Groq troppo generiche/passive che ripetono pattern
  // "Capisco." come risposta standalone è il segno che il modello non sa cosa dire
  // Block standalone OR "Capisco, [anything short]" patterns  
  const generic = /^(capisco\.?|ho capito\.?|capito\.?|ok\.?|mmh\.?|ah\.?|beh\.?|eh\.?)$/i;
  const startsWithCapisco = /^capisco[,.]?\s/i.test(s.trim()) && s.trim().length < 40;
  if (generic.test(s.trim()) || startsWithCapisco) {
    // Sostituisce con risposta neutrale che non rompe il frame
    const fallbacks = [
      "Dimmi di più.",
      "Raccontami.",
      "E poi?",
      "Vai avanti.",
    ];
    s = fallbacks[Math.floor(Math.random() * fallbacks.length)];
  }
  return s.trim() || "...";
}



// ---------- FINALIZE OUT (DM SAFE) ----------
function limitEmoji(out) {
  // tiene al massimo 1 emoji tra quelle che usiamo spesso
  let count = 0;
  return String(out || "")
    .replace(/[]/g, (m) => {
      count += 1;
      return count <= 1 ? m : "";
    })
    .replace(/\s{2,}/g, " ")
    .trim();
}

// --- DM output shaping: length + tone (varia con engagement/desire) ---
function dmHeat(st){
  const e = Number((st && st.engagement) || 0);
  const d = Number((st && st.desire) || 0);
  let h = (e * 0.6) + (d * 0.9);

  // se siamo gia' in fase funnel/push, alza un filo il "calore"
  const stage = (st && st.stage) ? String(st.stage) : "";
  if (/SOFT|MED|HARD|SELL|CLOSE|VIP/i.test(stage)) h += 1.5;

  return clamp(Math.round(h), 0, 10);
}

function dmMaxLen(st){
  const h = dmHeat(st);
  // 0..10 -> 140..240
  return Math.round(140 + (h * 10));
}

function applyHeatFlavor(out, st){
  const h = dmHeat(st);
  let s = String(out || "").trim();

  // Punteggiatura "spaziata" (es: "ciao ?" -> "ciao?")
  s = s.replace(/\s+([?!.,])/g, "$1")
       .replace(/\?{2,}/g, "?")
       .replace(/!{2,}/g, "!")
       .replace(/\.\.+/g, "...");

  // Inizio frase: evita "Ciao ?" e cose troppo "robot"
  s = s.replace(/^Ciao\?\s*/i, "Ciao ")
       .replace(/^Ah\s*ciao\s*/i, "Ciao ");

  // Se e' fredda/bassa: piu' secca, ma dolce
  if (h <= 3){
    s = s.replace(/Non preoccuparti/ig, "Tranquillo")
         .replace(/Mi fa piacere/ig, "Mi piace");
  }

  // Se e' calda/alta: un filo piu' "presa" e coinvolta (senza allungare troppo)
  if (h >= 7){
    // aggiungi un micro-gancio se manca una domanda e la frase e' corta
    // MA SOLO se non è un messaggio dalla coda (gift, link, tier)
    const hasQ = /\?\s*$/.test(s) || /\?/.test(s);
    const isQueuedMessage = /link|gift|tier|privato|accesso|sblocco/i.test(s.toLowerCase());
    if (!hasQ && s.length < 120 && !isQueuedMessage){
      s = s + " E tu?";
    }
    // un po' piu' morbida/complice
    s = s.replace(/Ok\b/ig, "Ok dai")
         .replace(/Va bene\b/ig, "Va bene dai");
  }

  return s.trim();
}

function italianStyleRewrite(out) {
  let s = String(out || "");

  // correzioni frasi "strane" ricorrenti
  const rules = [
    [/\bmi\s+stai\s+messo\b/gi, "mi hai messo"],
    [/\bnon\s+dire\s+bugie\b/gi, "ma dai, non prendermi in giro"],
    [/\bsei\s+solo\s+stato\s+a\s+vedere\s+una\s+sola\s+cosa\b/gi, "ti sei fissato su una cosa sola"],
    [/\bsei\s+solo\s+stato\s+a\s+vedere\b/gi, "ti sei fissato a guardare"],
    [/\buna\s+sola\s+cosa\s+sola\b/gi, "una cosa sola"],
    [/\buna\s+sola\s+cosa\b/gi, "una cosa sola"],
    [/\bsembra\s+un\s+po'\s+un\s+record\s+della\b/gi, "sembra un record da"],
    [/\bqual\s*['']\s*e\b/gi, "qual è"],
    [/\bperche\b/gi, "perché"],
    [/\bpo'\s*\?/gi, "po'?"],
  ];

  for (const [rx, rep] of rules) s = s.replace(rx, rep);

  // spaziatura punteggiatura
  s = s.replace(/\s+([,;:.!?])/g, "$1");
  s = s.replace(/([!?]){2,}/g, m => m.slice(0, 1)); // no "!!" "??"
  s = s.replace(/\?\s*\?/g, "?");
  s = s.replace(/\!\s*\!/g, "!");
  s = s.replace(/\s{2,}/g, " ").trim();

  // capitalizza la prima lettera se serve
  if (s && /[a-zàèéìòóù]/.test(s[0])) s = s[0].toUpperCase() + s.slice(1);

  return s;
}


function finalizeOut(text, st) {
  let out = String(text || "");

  out = antiPoliteRewrite(out);
  out = antiFormalTone(out);
  out = simplifyDM(out);
  out = italianStyleRewrite(out);

  out = applyHeatFlavor(out, st);

  // taglio dinamico (meno tronchi a caso: piu' spazio quando sale heat)
  out = trimForDM(out, dmMaxLen(st));

  // evita emoji random: massimo 1-2
  out = out.replace(/[😊😉😏🔥😌😂🤣😍😘🥺😅]+/g, m => m.slice(0, 2)).trim();

  return out;
}


// ---------- ULTRA REALISM PIPELINE ----------
function applyUltraRealism(out, st) {
  // Base pipeline (anti-educato + anti-formale + simplify + trim + max 1 emoji)
  let t = finalizeOut(out, st);

  // Emoji contestuale SOLO se non ne ha già una
  try {
    if (!/[]/.test(t)) {
      const lastUser = (st && st.ai_hist && st.ai_hist.length) ? (st.ai_hist[st.ai_hist.length - 1].content || "") : "";
      const cls = classifyUserMsg(lastUser, st);
      const flirtLevel = computeFlirtLevel(st || {}, cls);
      t = addContextEmoji(t, flirtLevel, (st && st.engagement) || 0);
