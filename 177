// Escalation contenuti "main" (gift + tiers)
function resolveContentAction(st) {
  // Progressione deterministica basata su acquisti (NON su desire).
  // Regole:
  // - prima GIFT una volta
  // - TIER2 richiede >=2 acquisti TIER1
  // - TIER3 richiede >=3 acquisti TIER2
  // - VIP richiede >=1 acquisto TIER3 (altrimenti continua su TIER3)

  if (!st.gift_sent) return "SEND_GIFT";

  const t1 = Number(st.tier1_purchases || 0);
  const t2 = Number(st.tier2_purchases || 0);
  const t3 = Number(st.tier3_purchases || 0);

  if (t1 < 1) return "SEND_TIER1";
  if (t2 < 1) return "SEND_TIER2";
  if (t3 < 1) return "SEND_TIER3";

  return "SEND_VIP";
}

// Escalation contenuti piedi (4 tier)
function resolveFeetAction(st) {
  // Progressione deterministica FEET (2 livelli) basata su stato pagamento (webhook) o confirm manuale.
  const level = Number(st.feet_level || 0);

  // Se NON ha ancora FEET1 -> proponi FEET1
  if (!st.feet_tier1_paid && level < 1) return "SEND_FEET_TIER1";

  // Se ha FEET1 ma NON FEET2 -> proponi FEET2
  if (!st.feet_tier2_paid && level < 2) return "SEND_FEET_TIER2";

  // Se ha FEET2 -> bridge nel funnel MAIN (Tier1)
  return "BRIDGE_TO_MAIN";
}

function resolveTwoStepAction(st, kind) {
  if (kind === "FEET") return resolveFeetAction(st);
  return resolveContentAction(st);
}


function resolveGiftLink(env) {
  // Accetta:
  // - JSON array: ["https://...","https://..."]
  // - JSON object: {"SOFT_GIFT":"https://..."} oppure {"GIFT":"https://..."} o qualsiasi key->url
  // - stringa singola: "https://..."
  // Nota: Cloudflare "Type: JSON" può fornire già un array/oggetto (non stringa).
  const raw = env.SOFT_GIFT_LINKS_JSON;

  function pickFromArray(arr) {
    const links = (arr || []).filter(x => typeof x === "string" && x.startsWith("http"));
    if (!links.length) return "";
    return links[Math.floor(Math.random() * links.length)];
  }

  // 1) già array (Type JSON)
  if (Array.isArray(raw)) return pickFromArray(raw);

  // 2) già oggetto (Type JSON)
  if (raw && typeof raw === "object") {
    const direct = raw.SOFT_GIFT || raw.soft_gift || raw.GIFT || raw.gift;
    if (typeof direct === "string" && direct.startsWith("http")) return direct;
    if (Array.isArray(direct)) return pickFromArray(direct);
    for (const k in raw) {
      const v = raw[k];
      if (typeof v === "string" && v.startsWith("http")) return v;
      if (Array.isArray(v)) {
        const p = pickFromArray(v);
        if (p) return p;
      }
    }
  }

  // 3) stringa: prova JSON.parse, altrimenti tratta come URL singolo
  if (typeof raw === "string" && raw.trim()) {
    const s = raw.trim();
    try {
      const parsed = JSON.parse(s);
      if (Array.isArray(parsed)) return pickFromArray(parsed);
      if (parsed && typeof parsed === "object") {
        const direct = parsed.SOFT_GIFT || parsed.soft_gift || parsed.GIFT || parsed.gift;
        if (typeof direct === "string" && direct.startsWith("http")) return direct;
        if (Array.isArray(direct)) return pickFromArray(direct);
        for (const k in parsed) {
          const v = parsed[k];
          if (typeof v === "string" && v.startsWith("http")) return v;
          if (Array.isArray(v)) {
            const p = pickFromArray(v);
            if (p) return p;
          }
        }
      }
    } catch (e) {
      // Se hai incollato direttamente un URL (non JSON), accettalo comunque
      if (s.startsWith("http")) return s;
      console.log("❌ Errore parsing SOFT_GIFT_LINKS_JSON:", String(e));
    }
  }

  // fallback
  const fallback = env.SOFT_LINK || env.GIFT_LINK || env.MAIN_LINK;
  return (typeof fallback === "string" ? fallback : "");
}

