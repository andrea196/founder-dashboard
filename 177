const GROQ_BLACKOUT_TTL_MS = 60 * 60 * 1000; // 1 ora
const GROQ_BLACKOUT_KV_PREFIX = "_groq_bo_";

/**
 * Legge il timestamp di blackout per un provider da KV.
 * Ritorna 0 se non in blackout o KV non disponibile.
 */
async function getProviderBlackout(providerKey, env) {
  try {
    const kv = getStateKV(env);
    if (!kv) return 0;
    const raw = await kv.get(GROQ_BLACKOUT_KV_PREFIX + providerKey).catch(() => null);
    return raw ? Number(raw) : 0;
  } catch (_) { return 0; }
}

/**
 * Segna un provider in blackout per 1 ora.
 */
async function setProviderBlackout(providerKey, env) {
  try {
    const kv = getStateKV(env);
    if (!kv) return;
    const ts = String(Date.now());
    // TTL = 2 ore in KV, ma la logica controlla 1 ora → margine sicuro
    await kv.put(GROQ_BLACKOUT_KV_PREFIX + providerKey, ts, { expirationTtl: 7200 }).catch(() => {});
    console.log(`V125: [${providerKey}] blackout settato per 1h`);
  } catch (_) {}
}

/**
 * Controlla se un provider è attualmente in blackout.
 */
async function isProviderBlackedOut(providerKey, env) {
  const ts = await getProviderBlackout(providerKey, env);
  if (!ts) return false;
  const elapsed = Date.now() - ts;
  if (elapsed >= GROQ_BLACKOUT_TTL_MS) return false; // scaduto
  console.log(`V125: [${providerKey}] in blackout ancora ${Math.round((GROQ_BLACKOUT_TTL_MS - elapsed) / 60000)}min`);
  return true;
}

/**
 * Chiama un singolo provider OpenAI-compatible.
 * Ritorna { ok: true, reply: "..." } oppure { ok: false, reason: "..." }
 */
async function callLLMProvider(baseUrl, apiKey, model, messages) {
  // V140 fix: OpenRouter usa /v1/chat/completions, altri provider /openai/v1/chat/completions
  const base = baseUrl.replace(/\/$/, "");
  const url = base.includes("openrouter.ai")
    ? base + "/v1/chat/completions"
    : base + "/openai/v1/chat/completions";
  try {
    const res = await fetch(url, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        Authorization: `Bearer ${apiKey}`,
      },
      body: JSON.stringify({
        model,
        messages,
        temperature: 0.85,
        max_tokens: 120,
      }),
    });
    if (!res.ok) {
      const errText = await res.text().catch(() => res.status);
      return { ok: false, reason: `HTTP ${res.status}: ${String(errText).slice(0, 120)}` };
    }
    const data = await res.json();
    const reply = data.choices?.[0]?.message?.content || "";
    if (!reply.trim()) return { ok: false, reason: "empty_response" };
    return { ok: true, reply: reply.trim() };
  } catch (err) {
    return { ok: false, reason: String(err).slice(0, 120) };
  }
}

