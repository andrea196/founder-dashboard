// MODULO 3: Obiezioni 3-step (prezzo / fiducia / rimando)
// Regex bilanciate: catturano frasi comuni SENZA falsi positivi eccessivi

function _isObjPrice(text) {
  const t = text.toLowerCase().trim();
  // Combo troppo+caro/costa o varianti
  if (/troppo caro|è caro|è troppo|costa troppo|costa tanto|costa molto|quanto costa/i.test(t)) return true;
  // "no dai troppo" / "ma troppo" / "troppo" a inizio o fine frase
  if (/\btroppo\b/i.test(t)) return true;
  // "non ho soldi" / "non posso pagare"
  if (/non ho soldi|non posso pagare|non ho i soldi|soldi non ho|non me lo posso permettere/i.test(t)) return true;
  // Parole singole forti
  if (/\b(caro|carissima|carissimo|costoso|costosa|esoso|cara)\b/i.test(t)) return true;
  // "costa" da solo o con "eh/ma/però"
  if (/\b(costa|costaa|costare)\b/i.test(t)) return true;
  return false;
}

function _isObjTrust(text) {
  const t = text.toLowerCase().trim();
  // "non so se/bene" / "non sono sicuro"
  if (/non so se|non sono sicuro|non sono sicura|non so bene|non mi fido|posso fidarmi/i.test(t)) return true;
  // "ma vero che X?" / "è vero?" / "funziona?"
  if (/(ma\s+)?vero che|è vero\??|ma vero\??|davvero funziona|funziona davvero|funziona\?/i.test(t)) return true;
  // "sicura?" / "sei sicura?" / "sicuro?" — con o senza "sei" davanti
  if (/\bsicura\?|sei sicura\??|sei sicuro\??|sicuro\?$/i.test(t)) return true;
  // "vero?" da solo
  if (/^vero\??$/.test(t)) return true;
  // truffa/fake/bot
  if (/è una truffa|sembra una truffa|sei un bot|sei un'ia|sei ai|sei vera\?|sei reale\?/i.test(t)) return true;
  // "non so" da solo in messaggio breve
  if (/\bnon so\b/i.test(t) && t.length < 20) return true;
  return false;
}

function _isObjDelay(text) {
  const t = text.toLowerCase().trim();
  // Frasi composte
  if (/ci penso|devo pensarci|forse dopo|più tardi|un'altra volta|non ora|non adesso|non è il momento|fammi pensare|ricontattami|fra un po'|un attimo|domani|dopodomani|la prossima settimana/i.test(t)) return true;
  // "magari" da solo o con "dopo/poi"
  if (/\bmagari\b/i.test(t)) return true;
  // "dopo" / "poi" da soli
  if (/^(dopo\.?|poi\.?)$/.test(t)) return true;
  return false;
}

