  // V76: Modulo 3 spostato PRIMA del blocco V60 (vedi sopra)

  // NORMAL AI RESPONSE WITH LIMITER
  const phase = st.stage === "WARMUP" ? "WARMUP" : (st.pending ? "PRE_ACTION" : "ACTIVE");
  routeLog(psid, st, "AI_REPLY", { phase });
  // V78 FIX: Rimuovi "Capisco." e varianti dall'ai_hist per non primere Groq a ripeterle
  if (Array.isArray(st.ai_hist)) {
