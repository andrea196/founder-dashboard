/**
 * Salva state con validazione pre-save
 */
async function saveStateSafe(psid, st, env) {
  try {
    // Validazione pre-save
    if (!st || typeof st !== 'object') {
      console.error(`Cannot save invalid state for ${psid}`);
      return false;
    }
    
    if (st.psid !== psid) {
      console.error(`State psid mismatch: ${st.psid} vs ${psid}`);
      st.psid = psid; // Fix
    }
    
    // Cleanup pre-save
    st.timed_queue = (st.timed_queue || []).filter(item => item && item.at);
    
    // V66 PHASE 1: DUAL WRITE INTERCEPT
    // Sincronizza awaiting_payment_tier <-> awaiting_offer prima del save
    if (st.awaiting_payment_tier !== undefined && st.awaiting_payment_tier !== null) {
      // Setta awaiting_offer basato su awaiting_payment_tier
      if (st.awaiting_payment_tier === 1 && st.awaiting_offer !== "t1") {
        st.awaiting_offer = "t1";
      } else if (st.awaiting_payment_tier === 2 && st.awaiting_offer !== "t2") {
        st.awaiting_offer = "t2";
      } else if (st.awaiting_payment_tier === 3 && st.awaiting_offer !== "t3") {
        st.awaiting_offer = "t3";
      } else if (st.awaiting_payment_tier === "feet1" && st.awaiting_offer !== "feet1") {
        st.awaiting_offer = "feet1";
      } else if (st.awaiting_payment_tier === "feet2" && st.awaiting_offer !== "feet2") {
        st.awaiting_offer = "feet2";
      }
    }
    // Reverse: se awaiting_payment_tier è null, assicurati che awaiting_offer lo sia anche
    if (st.awaiting_payment_tier === null && st.awaiting_offer !== null) {
      st.awaiting_offer = null;
    }
    
    const kv = getStateKV(env);
    if (!kv) {
      console.error("KV binding not found, cannot save");
      return false;
    }
    
    const serialized = JSON.stringify(st);
    await kv.put(stateKey(psid), serialized);
    
    return true;
  } catch (error) {
    console.error(`saveStateSafe error for ${psid}:`, String(error));
    return false;
  }
}

