    console.warn(`⚠️  TID non salvato in KV. Link con fallback PSID+premium: ${fullUrl}`);
  }
  
  console.log(`✅ Link completo generato: ${fullUrl}`);
  console.log(`✅ Premium: ${premium ? 'SI (+20%)' : 'NO (base)'}`);
  
  return fullUrl;
}

// FEET: tracked gateway url (TID-first, PSID fallback)
async function buildTrackedFeetGatewayUrl(psid, feetTier, env) {
  const base = getPublicBaseUrl(env);
  const tid = "t_" + crypto.randomUUID().replace(/-/g, "").slice(0, 24);

  // V67 FIX: usa getTrackingKV (coerente con invalidatePreviousTid e resolvePsidFromTid)
  // Prima usava env.TRACKING_KV hardcoded → invalidatePreviousTid non trovava il TID vecchio
  const KV = getTrackingKV(env);

  const payload = JSON.stringify({
    psid,
    kind: "feet",
    tier: feetTier,           // es: "feet2_reentry" — letto dal gateway feet
    premium: feetTier.includes("_reentry"), // true se reentry
    created_at: Date.now()
  });

  try {
    if (KV) {
      await KV.put(`tid:${tid}`, payload, { expirationTtl: 60 * 60 * 24 * 7 }); // 7d
      console.log(`✅ V67: TID feet salvato in KV: tid:${tid} → psid:${psid} (tier:${feetTier})`);
    } else {
      console.warn("⚠️  buildTrackedFeetGatewayUrl: KV non disponibile, TID non salvato");
    }
  } catch (e) {
    console.log("Tracking KV put failed (feet):", String(e));
  }

  const psidPart = psid ? `&psid=${encodeURIComponent(psid)}` : "";
  return `${base}/gateway/feet/${tid}?tier=${encodeURIComponent(feetTier)}${psidPart}`;
}



