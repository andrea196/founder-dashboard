    { max: 1,  key: "TIP_URL_1"  },
    { max: 2,  key: "TIP_URL_2"  },
    { max: 5,  key: "TIP_URL_5"  },
    { max: 10, key: "TIP_URL_10" },
    { max: 20, key: "TIP_URL_20" },
  ];
  // trova il prodotto più alto ≤ amount
  let best = null;
  for (const t of tiers) {
