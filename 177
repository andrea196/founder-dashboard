// ── 1. TIME SLOTS (Europe/Rome) ──────────────────────────────────────────────
function getRomeSlot(nowMs) {
  try {
    const d = new Date(nowMs || Date.now());
    const parts = new Intl.DateTimeFormat("it-IT", {
      timeZone: "Europe/Rome",
      hour: "2-digit", minute: "2-digit", hour12: false
    }).formatToParts(d);
    const hStr = parts.find(p => p.type === "hour")?.value || "12";
    const mStr = parts.find(p => p.type === "minute")?.value || "0";
    const h = parseInt(hStr, 10);
    const m = parseInt(mStr, 10);
    const totalMin = h * 60 + m;
    // quiet : 02:30–07:30
    if (totalMin >= 150 && totalMin < 450)  return "quiet";
    // morning: 07:30–11:30
    if (totalMin >= 450 && totalMin < 690)  return "morning";
    // day   : 11:30–18:30
    if (totalMin >= 690 && totalMin < 1110) return "day";
    // prime : 18:30–23:45
    if (totalMin >= 1110 && totalMin < 1425) return "prime";
    // late  : 23:45–02:30
    return "late";
  } catch (e) {
    console.warn("[PACING] Intl fallback (slot=day):", String(e).slice(0,60));
    return "day";
  }
}


