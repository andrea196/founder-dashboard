  if (!best) return null; // amount < 1 → nessun prodotto
  return env[best.key] || null;
}

// Parsa una cifra da testo italiano
// Gestisce: "3", "3 euro", "€3", "tre", "cinque", "dieci", "venti", "3,50", "3.5"
function parseTipAmount(text) {
  const t = (text || "").toLowerCase().trim();
  const words = {
    "uno":1,"un":1,"1":1,"2":2,"due":2,"tre":3,"3":3,"quattro":4,"4":4,
    "cinque":5,"5":5,"sei":6,"6":6,"sette":7,"7":7,"otto":8,"8":8,
    "nove":9,"9":9,"dieci":10,"10":10,"undici":11,"11":11,"dodici":12,"12":12,
    "quindici":15,"15":15,"venti":20,"20":20,"trenta":30,"30":30,
    "cinquanta":50,"50":50,"cento":100,"100":100
  };
  // cerca numero scritto in lettere
  for (const [word, val] of Object.entries(words)) {
    if (t.includes(word)) return val;
  }
  // cerca numero numerico (con €, "euro", virgola/punto decimale)
  const m = t.match(/[€$]?\s*(\d+(?:[.,]\d{1,2})?)/);
  if (m) return Math.floor(parseFloat(m[1].replace(",", ".")));
  return null;
}

